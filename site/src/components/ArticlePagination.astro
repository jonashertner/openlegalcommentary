---
// site/src/components/ArticlePagination.astro
import { type Lang, t } from '@/lib/i18n';
import { langBase } from '@/lib/base';

export interface Props {
  lang: Lang;
  law: string;
  prev: { slug: string; title: string } | null;
  next: { slug: string; title: string } | null;
}

const { lang, law, prev, next } = Astro.props;
---

<nav class="article-pagination" aria-label={t('pagination.prev', lang) + ' / ' + t('pagination.next', lang)}>
  {prev ? (
    <a href={`${langBase(lang)}/${law}/${prev.slug}`} class="pagination-link pagination-prev">
      <span class="pagination-arrow">&larr;</span>
      <span class="pagination-meta">
        <span class="pagination-direction text-xs">{t('pagination.prev', lang)}</span>
        <span class="pagination-title">{prev.title}</span>
      </span>
    </a>
  ) : <span />}

  {next ? (
    <a href={`${langBase(lang)}/${law}/${next.slug}`} class="pagination-link pagination-next">
      <span class="pagination-meta">
        <span class="pagination-direction text-xs">{t('pagination.next', lang)}</span>
        <span class="pagination-title">{next.title}</span>
      </span>
      <span class="pagination-arrow">&rarr;</span>
    </a>
  ) : <span />}
</nav>

<style>
  .article-pagination {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-5);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-rule-light);
    font-size: 12px;
  }

  .pagination-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .pagination-link:hover {
    color: var(--color-text);
  }

  .pagination-next {
    margin-left: auto;
    text-align: right;
  }

  .pagination-arrow {
    flex-shrink: 0;
  }

  .pagination-meta {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .pagination-direction {
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pagination-title {
    font-size: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .article-pagination {
      flex-direction: column;
      gap: var(--space-2);
    }

    .pagination-link {
      max-width: 100%;
    }

    .pagination-next {
      margin-left: 0;
      text-align: left;
    }
  }
</style>
