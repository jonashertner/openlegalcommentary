---
// site/src/components/ArticleTabs.astro
import { type Lang, t } from '@/lib/i18n';

interface TocEntry {
  level: number;
  text: string;
  id: string;
}

export interface Props {
  lang: Lang;
  summary: string;
  doctrine: string;
  caselaw: string;
  activeTab?: string;
  doctrineToc?: TocEntry[];
  caselawToc?: TocEntry[];
}

const {
  lang,
  summary, doctrine, caselaw,
  activeTab = 'summary',
  doctrineToc = [],
  caselawToc = [],
} = Astro.props;
---

<div class="tabs-container" data-active-tab={activeTab}>
  <div class="tabs-nav" role="tablist" aria-label="Kommentarebenen">
    <button
      role="tab"
      id="tab-summary"
      aria-controls="panel-summary"
      aria-selected={activeTab === 'summary' ? 'true' : 'false'}
      class:list={['tab-btn', { active: activeTab === 'summary' }]}
      data-tab="summary"
    >
      {t('tab.summary', lang)}
    </button>
    <button
      role="tab"
      id="tab-doctrine"
      aria-controls="panel-doctrine"
      aria-selected={activeTab === 'doctrine' ? 'true' : 'false'}
      class:list={['tab-btn', { active: activeTab === 'doctrine' }]}
      data-tab="doctrine"
    >
      {t('tab.doctrine', lang)}
    </button>
    <button
      role="tab"
      id="tab-caselaw"
      aria-controls="panel-caselaw"
      aria-selected={activeTab === 'caselaw' ? 'true' : 'false'}
      class:list={['tab-btn', { active: activeTab === 'caselaw' }]}
      data-tab="caselaw"
    >
      {t('tab.caselaw', lang)}
    </button>
    <div class="tab-indicator" id="tab-indicator"></div>
  </div>

  <div
    role="tabpanel"
    id="panel-summary"
    aria-labelledby="tab-summary"
    class:list={['tab-panel', 'prose', { hidden: activeTab !== 'summary' }]}
    data-panel="summary"
  >
    <Fragment set:html={summary} />
  </div>

  <div
    role="tabpanel"
    id="panel-doctrine"
    aria-labelledby="tab-doctrine"
    class:list={['tab-panel', 'prose', { hidden: activeTab !== 'doctrine' }]}
    data-panel="doctrine"
  >
    {doctrineToc.length > 2 && (
      <nav class="toc" aria-label={t('article.toc', lang)}>
        <details open>
          <summary class="toc-toggle">
            <span class="toc-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 3h10M2 7h7M2 11h10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </span>
            {t('article.toc', lang)}
          </summary>
          <ol class="toc-list">
            {doctrineToc.map((entry) => (
              <li class:list={[{ 'toc-sub': entry.level === 3 }]}>
                <a href={`#${entry.id}`}>{entry.text}</a>
              </li>
            ))}
          </ol>
        </details>
      </nav>
    )}
    <Fragment set:html={doctrine} />
  </div>

  <div
    role="tabpanel"
    id="panel-caselaw"
    aria-labelledby="tab-caselaw"
    class:list={['tab-panel', 'prose', { hidden: activeTab !== 'caselaw' }]}
    data-panel="caselaw"
  >
    {caselawToc.length > 2 && (
      <nav class="toc" aria-label={t('article.toc', lang)}>
        <details open>
          <summary class="toc-toggle">
            <span class="toc-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 3h10M2 7h7M2 11h10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </span>
            {t('article.toc', lang)}
          </summary>
          <ol class="toc-list">
            {caselawToc.map((entry) => (
              <li class:list={[{ 'toc-sub': entry.level === 3 }]}>
                <a href={`#${entry.id}`}>{entry.text}</a>
              </li>
            ))}
          </ol>
        </details>
      </nav>
    )}
    <Fragment set:html={caselaw} />
  </div>
</div>

<style>
  .tabs-nav {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--color-border-light);
    margin-bottom: var(--space-3);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    position: relative;
  }

  .tab-indicator {
    position: absolute;
    bottom: 0;
    height: 2px;
    background: var(--color-accent);
    transition: transform 0.3s var(--ease-out), width 0.3s var(--ease-out);
    border-radius: 1px;
  }

  .tab-btn {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-tab-inactive);
    background: none;
    border: none;
    padding: var(--space-1) var(--space-2);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    white-space: nowrap;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .tab-btn:hover {
    color: var(--color-text);
  }

  .tab-btn.active {
    color: var(--color-tab-active);
    font-weight: 600;
  }

  .tab-panel {
    padding: var(--space-2) 0;
  }

  .tab-panel.hidden {
    display: none;
  }

  /* Table of Contents */
  .toc {
    margin-bottom: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-alt);
    overflow: hidden;
  }

  .toc-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .toc-toggle::-webkit-details-marker { display: none; }

  .toc-toggle::after {
    content: '';
    margin-left: auto;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid var(--color-text-muted);
    transition: transform var(--transition-fast);
  }

  details[open] > .toc-toggle::after {
    transform: rotate(180deg);
  }

  .toc-icon {
    display: flex;
    align-items: center;
    color: var(--color-accent);
  }

  .toc-list {
    list-style: none;
    padding: 0 var(--space-2) var(--space-2);
    margin: 0;
    counter-reset: toc;
  }

  .toc-list li {
    margin: 0;
  }

  .toc-list li a {
    display: block;
    padding: 0.25rem 0.5rem;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
    line-height: 1.4;
  }

  .toc-list li a:hover {
    color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .toc-list li.toc-active a {
    color: var(--color-accent);
    font-weight: 600;
  }

  .toc-sub {
    padding-left: 1.25rem;
  }

  .toc-sub a {
    font-size: var(--text-xs) !important;
  }

  @media (max-width: 768px) {
    .tab-btn {
      flex: 1;
      text-align: center;
      padding: var(--space-1);
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  // Tab indicator positioning
  function updateIndicator() {
    const activeTab = document.querySelector('.tab-btn[aria-selected="true"]') || document.querySelector('.tab-btn.active');
    const indicator = document.getElementById('tab-indicator');
    if (activeTab && indicator) {
      const btn = activeTab as HTMLElement;
      indicator.style.width = btn.offsetWidth + 'px';
      indicator.style.transform = `translateX(${btn.offsetLeft}px)`;
    }
  }

  // Tab switching with URL parameter support
  function initTabs() {
    const container = document.querySelector('.tabs-container');
    if (!container) return;

    const buttons = container.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels = container.querySelectorAll<HTMLElement>('.tab-panel');

    function switchTab(tabName: string) {
      buttons.forEach((btn) => {
        const isActive = btn.dataset.tab === tabName;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-selected', String(isActive));
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.panel === tabName;
        panel.classList.toggle('hidden', !isActive);
      });

      updateIndicator();

      // Update URL without reload
      const url = new URL(window.location.href);
      if (tabName === 'summary') {
        url.searchParams.delete('layer');
      } else {
        url.searchParams.set('layer', tabName);
      }
      history.replaceState({}, '', url.toString());
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        if (tab) switchTab(tab);
      });
    });

    // Check URL for initial tab
    const params = new URLSearchParams(window.location.search);
    const layer = params.get('layer');
    if (layer && ['summary', 'doctrine', 'caselaw'].includes(layer)) {
      switchTab(layer);
    }

    // Initialize indicator position
    updateIndicator();
  }

  initTabs();

  // TOC active section tracking via IntersectionObserver
  function initTocTracking() {
    const tocLinks = document.querySelectorAll('.toc-list li a');
    if (tocLinks.length === 0) return;

    const headingIds = Array.from(tocLinks).map((a) => {
      const href = a.getAttribute('href');
      return href ? href.slice(1) : '';
    }).filter(Boolean);

    const headings = headingIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    if (headings.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach((link) => {
              const li = link.parentElement;
              if (!li) return;
              li.classList.toggle(
                'toc-active',
                link.getAttribute('href') === `#${id}`
              );
            });
          }
        }
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
  }

  initTocTracking();
</script>
