---
// site/src/components/LawCard.astro
import { type Lang, t } from '@/lib/i18n';
import { langBase } from '@/lib/base';
import type { LawInfo } from '../lib/laws';
import type { LawStats } from '../lib/content';

export interface Props {
  lang: Lang;
  law: LawInfo;
  stats: LawStats;
}

const { lang, law, stats } = Astro.props;
const href = `${langBase(lang)}/${law.abbr.toLowerCase()}`;
---

<a href={href} class="law-card">
  <div class="law-card-top">
    <div class="law-card-abbr-row">
      <span class="law-abbr">{law.abbr}</span>
      <span class="law-sr font-mono">{law.sr}</span>
    </div>
    <h2 class="law-name">{law.name[lang]}</h2>
    <p class="law-desc">{law.description[lang]}</p>
  </div>
  <div class="law-card-bottom">
    <div class="law-articles-count">
      <span class="law-count-value">{stats.totalArticles}</span>
      <span class="law-count-label">{t('home.stat.articles', lang)}</span>
    </div>
    {stats.withContent > 0 && (
      <div class="law-card-progress">
        <div class="law-progress-bar">
          <div class="law-progress-fill" style={`width: ${Math.max(stats.withContent / stats.totalArticles * 100, 1)}%`}></div>
        </div>
        <span class="law-progress-pct">{Math.round(stats.withContent / stats.totalArticles * 100)}%</span>
      </div>
    )}
    <span class="law-card-arrow" aria-hidden="true">&rarr;</span>
  </div>
</a>

<style>
  .law-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-3) var(--space-3) var(--space-2);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
    min-height: 160px;
    position: relative;
    overflow: hidden;
  }

  .law-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }

  .law-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .law-card:hover::before {
    transform: scaleX(1);
  }

  .law-card-top {
    flex: 1;
  }

  .law-card-abbr-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
    margin-bottom: 6px;
  }

  .law-abbr {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-xl);
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .law-sr {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .law-name {
    font-size: var(--text-sm);
    font-weight: 600;
    margin: 0 0 4px 0;
    line-height: 1.3;
  }

  .law-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.4;
    margin: 0;
  }

  .law-card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border-light);
    margin-top: var(--space-2);
  }

  .law-articles-count {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .law-count-value {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-md);
    color: var(--color-text);
  }

  .law-count-label {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .law-card-progress {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .law-progress-bar {
    width: 48px;
    height: 3px;
    background: var(--color-bg-alt);
    border-radius: 2px;
    overflow: hidden;
  }

  .law-progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .law-progress-pct {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-muted);
  }

  .law-card-arrow {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .law-card:hover .law-card-arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  .law-card:hover .law-abbr {
    color: var(--color-accent);
    transition: color var(--transition-base);
  }
</style>
