---
import type { ArticleTextParagraph } from '../lib/content';

interface Props {
  paragraphs: ArticleTextParagraph[];
  i18n?: Record<string, ArticleTextParagraph[]>;
  articleDisplay: string;
  fedlexUrl: string;
}

const { paragraphs, i18n = {}, articleDisplay, fedlexUrl } = Astro.props;
const hasParagraphs = paragraphs.length > 0;

// Build Fedlex URLs per language
function fedlexLangUrl(url: string, lang: string): string {
  if (!url) return '';
  return url.replace(/\/(de|fr|it)(#|$)/, `/${lang}$2`);
}
---

{hasParagraphs && (
  <section class="gesetzestext">
    <div class="gesetzestext-header">
      <div class="gesetzestext-label">
        <span class="gesetzestext-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 1.5h7l3 3V14a.5.5 0 01-.5.5h-9A.5.5 0 013 14V2a.5.5 0 01.5-.5z" stroke="currentColor" stroke-width="1.2"/>
            <path d="M10 1.5V4.5h3" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5.5 7.5h5M5.5 9.5h5M5.5 11.5h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </span>
        <span data-gesetz-label>Gesetzestext</span>
      </div>
      <a href={fedlexUrl} target="_blank" rel="noopener" class="gesetzestext-source" data-gesetz-fedlex>
        Fedlex &nearr;
      </a>
    </div>
    <div class="gesetzestext-body" data-gesetz-body>
      {paragraphs.map((p) => {
        if (p.type === 'list' && p.items) {
          return (
            <dl class="gesetzestext-list">
              {p.items.map((item) => (
                <>
                  <dt>{item.letter}</dt>
                  <dd>{item.text}</dd>
                </>
              ))}
            </dl>
          );
        }
        return (
          <p class:list={['gesetzestext-absatz', { 'has-num': !!p.num }]}>
            {p.num && <span class="absatz-num">{p.num}</span>}
            <span class="absatz-text">{p.text}</span>
          </p>
        );
      })}
    </div>
    {Object.keys(i18n).length > 1 && (
      <script
        id="gesetzestext-i18n"
        type="application/json"
        set:html={JSON.stringify({
          texts: i18n,
          fedlexUrls: Object.fromEntries(
            ['de', 'fr', 'it'].map(l => [l, fedlexLangUrl(fedlexUrl, l)])
          ),
          labels: { de: 'Gesetzestext', fr: 'Texte de loi', it: 'Testo di legge' },
        })}
      />
    )}
  </section>
)}

<style>
  .gesetzestext {
    margin-bottom: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    overflow: hidden;
    animation: fadeUp 0.5s var(--ease-out) 0.1s both;
  }

  .gesetzestext-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-3);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .gesetzestext-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .gesetzestext-icon {
    display: flex;
    align-items: center;
    color: var(--color-accent);
  }

  .gesetzestext-source {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .gesetzestext-source:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .gesetzestext-body {
    padding: var(--space-3) var(--space-3) var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text);
  }

  .gesetzestext-absatz {
    margin-bottom: 0.75rem;
    max-width: none;
    display: flex;
    align-items: baseline;
    gap: 0;
    padding: 0.25rem 0;
  }

  .gesetzestext-absatz:last-child {
    margin-bottom: 0;
  }

  /* Numbered paragraphs get a subtle left border on hover for readability */
  .gesetzestext-absatz.has-num {
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast);
  }

  .gesetzestext-absatz.has-num:hover {
    background: var(--color-bg-alt);
  }

  .gesetzestext-absatz:not(.has-num) {
    display: block;
    padding-left: 0;
  }

  .absatz-num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    min-width: 1.75rem;
    height: 1.25rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.65rem;
    color: var(--color-accent);
    background: var(--color-accent-light);
    border-radius: 3px;
    margin-right: 0.625rem;
    line-height: 1;
    user-select: none;
  }

  .absatz-text {
    flex: 1;
  }

  /* Separator between paragraphs for visual clarity */
  .gesetzestext-absatz + .gesetzestext-list,
  .gesetzestext-list + .gesetzestext-absatz {
    margin-top: 0.25rem;
  }

  .gesetzestext-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 0.75rem;
    margin: 0 0 0.75rem 2.375rem;
    padding: 0.375rem 0;
    border-left: 2px solid var(--color-border);
    padding-left: 0.75rem;
  }

  .gesetzestext-list dt {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-xs);
    color: var(--color-accent);
    padding-top: 0.15rem;
    min-width: 1.25rem;
  }

  .gesetzestext-list dd {
    margin: 0;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .gesetzestext-body {
      padding: var(--space-2);
    }

    .gesetzestext-list {
      margin-left: 0.5rem;
      padding-left: 0.625rem;
    }

    .absatz-num {
      width: 1.5rem;
      min-width: 1.5rem;
      margin-right: 0.5rem;
    }
  }
</style>

<script>
  document.addEventListener('lang-change', (e: Event) => {
    const { lang } = (e as CustomEvent).detail;
    const dataEl = document.getElementById('gesetzestext-i18n');
    if (!dataEl) return;

    try {
      const data = JSON.parse(dataEl.textContent || '{}');
      const paragraphs = data.texts?.[lang];
      if (!paragraphs) return;

      // Update body
      const body = document.querySelector('[data-gesetz-body]');
      if (body) {
        body.replaceChildren();
        for (const p of paragraphs) {
          if (p.type === 'list' && p.items) {
            const dl = document.createElement('dl');
            dl.className = 'gesetzestext-list';
            for (const item of p.items) {
              const dt = document.createElement('dt');
              dt.textContent = item.letter;
              const dd = document.createElement('dd');
              dd.textContent = item.text;
              dl.appendChild(dt);
              dl.appendChild(dd);
            }
            body.appendChild(dl);
          } else {
            const el = document.createElement('p');
            el.className = 'gesetzestext-absatz' + (p.num ? ' has-num' : '');
            if (p.num) {
              const numSpan = document.createElement('span');
              numSpan.className = 'absatz-num';
              numSpan.textContent = p.num;
              el.appendChild(numSpan);
            }
            const textSpan = document.createElement('span');
            textSpan.className = 'absatz-text';
            textSpan.textContent = p.text || '';
            el.appendChild(textSpan);
            body.appendChild(el);
          }
        }
      }

      // Update label
      const label = document.querySelector('[data-gesetz-label]');
      if (label && data.labels?.[lang]) {
        label.textContent = data.labels[lang];
      }

      // Update Fedlex link
      const fedlex = document.querySelector('[data-gesetz-fedlex]') as HTMLAnchorElement;
      if (fedlex && data.fedlexUrls?.[lang]) {
        fedlex.href = data.fedlexUrls[lang];
      }
    } catch {
      // Ignore parse errors
    }
  });
</script>
