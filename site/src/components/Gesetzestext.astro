---
import type { ArticleTextParagraph } from '../lib/content';
import { type Lang, t } from '../lib/i18n';

interface Props {
  paragraphs: ArticleTextParagraph[];
  lang: Lang;
  articleDisplay: string;
  fedlexUrl: string;
}

const { paragraphs, lang, articleDisplay, fedlexUrl } = Astro.props;
const hasParagraphs = paragraphs.length > 0;

// Build Fedlex URL for the given language
function fedlexLangUrl(url: string, l: string): string {
  if (!url) return '';
  return url.replace(/\/(de|fr|it)(#|$)/, `/${l}$2`);
}

const resolvedFedlexUrl = fedlexLangUrl(fedlexUrl, lang);

// Strip footnote reference numbers (e.g., "b.128" → "b.", "text130" → "text")
function stripFootnotes(text: string): string {
  return text.replace(/(\D)\d{2,3}$/g, '$1').replace(/(\D)\d{2,3}(\s)/g, '$1$2').trim();
}
function stripLetterFootnote(letter: string): string {
  return letter.replace(/^([a-z](?:bis|ter|quater)?\.?)\d+$/i, '$1');
}
---

{hasParagraphs && (
  <section class="gesetzestext">
    <div class="gesetzestext-header">
      <div class="gesetzestext-label">
        <span class="gesetzestext-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 1.5h7l3 3V14a.5.5 0 01-.5.5h-9A.5.5 0 013 14V2a.5.5 0 01.5-.5z" stroke="currentColor" stroke-width="1.2"/>
            <path d="M10 1.5V4.5h3" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5.5 7.5h5M5.5 9.5h5M5.5 11.5h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </span>
        <span>{t('gesetzestext.label', lang)}</span>
      </div>
      <a href={resolvedFedlexUrl} target="_blank" rel="noopener" class="gesetzestext-source">
        Fedlex &nearr;
      </a>
    </div>
    <div class="gesetzestext-body">
      {paragraphs.map((p) => {
        if (p.type === 'list' && p.items) {
          return (
            <dl class="gesetzestext-list">
              {p.items.map((item) => (
                <>
                  <dt>{stripLetterFootnote(item.letter)}</dt>
                  <dd>{stripFootnotes(item.text)}</dd>
                </>
              ))}
            </dl>
          );
        }
        return (
          <p class:list={['gesetzestext-absatz', { 'has-num': !!p.num }]}>
            {p.num && <span class="absatz-num">{p.num}</span>}
            <span class="absatz-text">{stripFootnotes(p.text)}</span>
          </p>
        );
      })}
    </div>
  </section>
)}

<style>
  .gesetzestext {
    margin-bottom: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    overflow: hidden;
    animation: fadeUp 0.5s var(--ease-out) 0.1s both;
  }

  .gesetzestext-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-3);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .gesetzestext-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .gesetzestext-icon {
    display: flex;
    align-items: center;
    color: var(--color-accent);
  }

  .gesetzestext-source {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .gesetzestext-source:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .gesetzestext-body {
    padding: var(--space-3) var(--space-3) var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text);
  }

  /* Use :global() for all children of gesetzestext-body
     because Astro's scoped data attributes may not apply to
     dynamically constructed elements in some rendering paths */
  .gesetzestext-body :global(.gesetzestext-absatz) {
    margin-bottom: 0.75rem;
    max-width: none;
    display: flex;
    align-items: baseline;
    gap: 0;
    padding: 0.25rem 0;
  }

  .gesetzestext-body :global(.gesetzestext-absatz:last-child) {
    margin-bottom: 0;
  }

  .gesetzestext-body :global(.gesetzestext-absatz.has-num) {
    border-radius: var(--radius-sm);
    transition: background 150ms ease-out;
  }

  .gesetzestext-body :global(.gesetzestext-absatz.has-num:hover) {
    background: var(--color-bg-alt);
  }

  .gesetzestext-body :global(.gesetzestext-absatz:not(.has-num)) {
    display: block;
    padding-left: 0;
  }

  .gesetzestext-body :global(.absatz-num) {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    min-width: 1.75rem;
    height: 1.25rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.65rem;
    color: var(--color-accent);
    background: var(--color-accent-light);
    border-radius: 3px;
    margin-right: 0.625rem;
    line-height: 1;
    user-select: none;
  }

  .gesetzestext-body :global(.absatz-text) {
    flex: 1;
  }

  .gesetzestext-body :global(.gesetzestext-absatz + .gesetzestext-list),
  .gesetzestext-body :global(.gesetzestext-list + .gesetzestext-absatz) {
    margin-top: 0.25rem;
  }

  .gesetzestext-body :global(.gesetzestext-list) {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 0.75rem;
    margin: 0 0 0.75rem 2.375rem;
    padding: 0.375rem 0;
    border-left: 2px solid var(--color-border);
    padding-left: 0.75rem;
  }

  .gesetzestext-body :global(.gesetzestext-list dt) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-xs);
    color: var(--color-accent);
    padding-top: 0.15rem;
    min-width: 1.25rem;
  }

  .gesetzestext-body :global(.gesetzestext-list dd) {
    margin: 0;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .gesetzestext-body {
      padding: var(--space-2);
    }

    .gesetzestext-body :global(.gesetzestext-list) {
      margin-left: 0.5rem;
      padding-left: 0.625rem;
    }

    .gesetzestext-body :global(.absatz-num) {
      width: 1.5rem;
      min-width: 1.5rem;
      margin-right: 0.5rem;
    }
  }
</style>
