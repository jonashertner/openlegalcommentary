---
import type { ArticleTextParagraph } from '../lib/content';

interface Props {
  paragraphs: ArticleTextParagraph[];
  articleDisplay: string;
  fedlexUrl: string;
}

const { paragraphs, articleDisplay, fedlexUrl } = Astro.props;
const hasParagraphs = paragraphs.length > 0;
---

{hasParagraphs && (
  <section class="gesetzestext">
    <div class="gesetzestext-header">
      <div class="gesetzestext-label">
        <span class="gesetzestext-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 1.5h7l3 3V14a.5.5 0 01-.5.5h-9A.5.5 0 013 14V2a.5.5 0 01.5-.5z" stroke="currentColor" stroke-width="1.2"/>
            <path d="M10 1.5V4.5h3" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5.5 7.5h5M5.5 9.5h5M5.5 11.5h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </span>
        Gesetzestext
      </div>
      <a href={fedlexUrl} target="_blank" rel="noopener" class="gesetzestext-source">
        Fedlex &nearr;
      </a>
    </div>
    <div class="gesetzestext-body">
      {paragraphs.map((p) => {
        if (p.type === 'list' && p.items) {
          return (
            <dl class="gesetzestext-list">
              {p.items.map((item) => (
                <>
                  <dt>{item.letter}</dt>
                  <dd>{item.text}</dd>
                </>
              ))}
            </dl>
          );
        }
        return (
          <p class:list={['gesetzestext-absatz', { 'has-num': !!p.num }]}>
            {p.num && <span class="absatz-num">{p.num}</span>}
            <span class="absatz-text">{p.text}</span>
          </p>
        );
      })}
    </div>
  </section>
)}

<style>
  .gesetzestext {
    margin-bottom: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    overflow: hidden;
    animation: fadeUp 0.5s var(--ease-out) 0.1s both;
  }

  .gesetzestext-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-3);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .gesetzestext-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .gesetzestext-icon {
    display: flex;
    align-items: center;
    color: var(--color-accent);
  }

  .gesetzestext-source {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .gesetzestext-source:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .gesetzestext-body {
    padding: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text);
  }

  .gesetzestext-absatz {
    margin-bottom: 0.625rem;
    max-width: none;
    display: flex;
    gap: 0;
  }

  .gesetzestext-absatz:last-child {
    margin-bottom: 0;
  }

  .gesetzestext-absatz:not(.has-num) {
    display: block;
  }

  .absatz-num {
    flex-shrink: 0;
    display: inline-block;
    width: 2rem;
    min-width: 2rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.7rem;
    color: var(--color-accent);
    vertical-align: super;
    line-height: 1;
    padding-top: 0.35rem;
  }

  .absatz-text {
    flex: 1;
  }

  .gesetzestext-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.125rem 0.75rem;
    margin: 0.25rem 0 0.625rem 2rem;
    padding: 0;
  }

  .gesetzestext-list dt {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    padding-top: 0.15rem;
  }

  .gesetzestext-list dd {
    margin: 0;
  }

  @media (max-width: 768px) {
    .gesetzestext-body {
      padding: var(--space-2);
    }

    .gesetzestext-list {
      margin-left: 1rem;
    }

    .absatz-num {
      width: 1.5rem;
      min-width: 1.5rem;
    }
  }
</style>
