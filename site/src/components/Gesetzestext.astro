---
import type { ArticleTextParagraph } from '../lib/content';
import { type Lang, t } from '../lib/i18n';

interface Props {
  paragraphs: ArticleTextParagraph[];
  lang: Lang;
  articleDisplay: string;
  fedlexUrl: string;
}

const { paragraphs, lang, articleDisplay, fedlexUrl } = Astro.props;
const hasParagraphs = paragraphs.length > 0;

// Build Fedlex URL for the given language
function fedlexLangUrl(url: string, l: string): string {
  if (!url) return '';
  return url.replace(/\/(de|fr|it|en)(#|$)/, `/${l}$2`);
}

const resolvedFedlexUrl = fedlexLangUrl(fedlexUrl, lang);

// Strip footnote reference numbers from text
// Only strip numbers that are clearly superscript footnote refs:
// - After a period at end: "text.129" → "text."
// - After a closing paren: "text)130" → "text)"
// Do NOT strip numbers after spaces (those are content like "4000 Angehörige")
function stripFootnotes(text: string): string {
  return text
    // Remove footnote number after period at end: "Satz.129" → "Satz."
    .replace(/(\.)(\d{2,3})$/g, '$1')
    // Remove footnote number after closing paren at end: "text)130" → "text)"
    .replace(/(\))(\d{2,3})$/g, '$1')
    .trim();
}
function stripLetterFootnote(letter: string): string {
  // "b.128" → "b." but NOT "128" alone
  return letter.replace(/^([a-z](?:bis|ter|quater)?\.)\d+$/i, '$1');
}

// Filter out amendment note paragraphs that got parsed as regular content
const amendmentPatterns = [
  /^Angenommen in der Volksabstimmung/i,
  /^Eingefügt durch/i,
  /^Aufgehoben durch/i,
  /^Fassung gemäss/i,
  /^Adopted by the popular vote/i,
  /^Inserted by/i,
  /^Repealed by/i,
  /^Amended by/i,
  /^Accepté en votation populaire/i,
  /^Introduit par/i,
  /^Abrogé par/i,
  /^Adopté par/i,
  /^Accettato nella votazione popolare/i,
  /^Introdotto/i,
  /^Abrogato/i,
];
function isAmendmentNote(text: string): boolean {
  return amendmentPatterns.some(p => p.test(text.trim()));
}

// Clean paragraphs: filter amendments and footnote paragraphs, strip footnote numbers
const cleanParagraphs = paragraphs.filter(p => {
  if (p.text && isAmendmentNote(p.text)) return false;
  // Filter out footnote paragraphs: high num + amendment text pattern
  if (p.num && parseInt(p.num, 10) >= 20 && p.text && isAmendmentNote(p.text)) return false;
  // Also filter standalone high-numbered footnotes referencing AS/BBl/FedD
  if (p.num && parseInt(p.num, 10) >= 20 && p.text && /\b(AS|BBl|FedD|BRB|BB vom|FCD)\b/.test(p.text)) return false;
  return true;
}).map(p => {
  if (p.type === 'list' && p.items) {
    return {
      ...p,
      items: p.items.filter(item => !isAmendmentNote(item.text)).map(item => ({
        letter: stripLetterFootnote(item.letter),
        text: stripFootnotes(item.text),
      })),
    };
  }
  return { ...p, text: p.text ? stripFootnotes(p.text) : p.text };
});
---

{cleanParagraphs.length > 0 && (
  <section class="gesetzestext">
    <div class="gesetzestext-header">
      <div class="gesetzestext-label">
        <span>{t('gesetzestext.label', lang)}</span>
      </div>
      {resolvedFedlexUrl && (
        <a href={resolvedFedlexUrl} target="_blank" rel="noopener" class="gesetzestext-source">
          Fedlex &nearr;
        </a>
      )}
    </div>
    <div class="gesetzestext-body">
      {cleanParagraphs.map((p) => {
        if (p.type === 'list' && p.items) {
          return (
            <dl class="gesetzestext-list">
              {p.items.map((item) => (
                <>
                  <dt>{item.letter}</dt>
                  <dd>{item.text}</dd>
                </>
              ))}
            </dl>
          );
        }
        return (
          <p class:list={['gesetzestext-absatz', { 'has-num': !!p.num }]}>
            {p.num && <span class="absatz-num">{p.num}</span>}
            <span class="absatz-text">{p.text}</span>
          </p>
        );
      })}
    </div>
  </section>
)}

<style>
  .gesetzestext {
    margin-bottom: var(--space-4);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .gesetzestext-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .gesetzestext-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .gesetzestext-source {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .gesetzestext-source:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .gesetzestext-body {
    padding: var(--space-3) var(--space-3) var(--space-2);
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* Use :global() for all children of gesetzestext-body
     because Astro's scoped data attributes may not apply to
     dynamically constructed elements in some rendering paths */
  .gesetzestext-body :global(.gesetzestext-absatz) {
    margin-bottom: 0.75rem;
    max-width: none;
    display: flex;
    align-items: baseline;
    gap: 0;
    padding: 0.25rem 0;
  }

  .gesetzestext-body :global(.gesetzestext-absatz:last-child) {
    margin-bottom: 0;
  }

  .gesetzestext-body :global(.gesetzestext-absatz.has-num) {
    transition: background 150ms ease-out;
  }

  .gesetzestext-body :global(.gesetzestext-absatz.has-num:hover) {
    background: var(--color-rule-light);
  }

  .gesetzestext-body :global(.gesetzestext-absatz:not(.has-num)) {
    display: block;
    padding-left: 0;
  }

  .gesetzestext-body :global(.absatz-num) {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    min-width: 1.75rem;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 11px;
    color: var(--color-text-muted);
    margin-right: 0.625rem;
    line-height: 1;
    user-select: none;
  }

  .gesetzestext-body :global(.absatz-text) {
    flex: 1;
  }

  .gesetzestext-body :global(.gesetzestext-absatz + .gesetzestext-list),
  .gesetzestext-body :global(.gesetzestext-list + .gesetzestext-absatz) {
    margin-top: 0.25rem;
  }

  .gesetzestext-body :global(.gesetzestext-list) {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 0.75rem;
    margin: 0 0 0.75rem 2.375rem;
    padding: 0.375rem 0;
    border-left: 2px solid var(--color-border);
    padding-left: 0.75rem;
  }

  .gesetzestext-body :global(.gesetzestext-list dt) {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 11px;
    color: var(--color-text-muted);
    padding-top: 0.15rem;
    min-width: 1.25rem;
  }

  .gesetzestext-body :global(.gesetzestext-list dd) {
    margin: 0;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .gesetzestext-body {
      padding: var(--space-2);
    }

    .gesetzestext-body :global(.gesetzestext-list) {
      margin-left: 0.5rem;
      padding-left: 0.625rem;
    }

    .gesetzestext-body :global(.absatz-num) {
      width: 1.5rem;
      min-width: 1.5rem;
      margin-right: 0.5rem;
    }
  }
</style>
