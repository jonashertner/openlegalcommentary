---
interface Props {
  placeholder?: string;
  autofocus?: boolean;
}

const { placeholder = 'Artikel suchen — z.B. "Art. 41 OR" oder "Haftung"', autofocus = false } = Astro.props;
---

<div class="search-container">
  <div class="search-input-wrap">
    <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="7" cy="7" r="5" /><path d="M11 11l3.5 3.5" stroke-linecap="round" />
    </svg>
    <input
      type="search"
      id="article-search"
      class="search-input"
      placeholder={placeholder}
      autocomplete="off"
      autofocus={autofocus}
    />
    <kbd class="search-kbd" id="search-kbd">/</kbd>
  </div>
  <div class="search-results" id="search-results" hidden>
    <ul class="search-results-list" id="search-results-list"></ul>
    <div class="search-empty" id="search-empty" hidden>
      Keine Artikel gefunden.
    </div>
  </div>
</div>

<style>
  .search-container {
    position: relative;
    max-width: 560px;
    width: 100%;
  }

  .search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 10px 14px 10px 40px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-light);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }

  .search-kbd {
    position: absolute;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1px 6px;
    line-height: 1.4;
    pointer-events: none;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    max-height: 360px;
    overflow-y: auto;
    z-index: 100;
  }

  .search-results-list {
    list-style: none;
    padding: 4px;
    margin: 0;
  }

  .search-results-list :global(li) {
    margin: 0;
  }

  .search-results-list :global(a) {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: 8px 12px;
    text-decoration: none;
    color: var(--color-text);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    transition: background var(--transition-fast);
  }

  .search-results-list :global(a:hover),
  .search-results-list :global(a.active) {
    background: var(--color-bg-alt);
  }

  .search-results-list :global(.sr-law) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    min-width: 40px;
    font-weight: 600;
  }

  .search-results-list :global(.sr-num) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    min-width: 56px;
  }

  .search-results-list :global(.sr-title) {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-empty {
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-align: center;
  }

  @media (max-width: 768px) {
    .search-kbd {
      display: none;
    }
  }
</style>

<script>
  let searchIndex: { l: string; n: string; t: string; u: string }[] | null = null;
  let activeIndex = -1;

  const input = document.getElementById('article-search') as HTMLInputElement;
  const results = document.getElementById('search-results')!;
  const resultsList = document.getElementById('search-results-list')!;
  const emptyEl = document.getElementById('search-empty')!;
  const kbdEl = document.getElementById('search-kbd')!;

  const BASE = (document.querySelector('meta[name="base-url"]')?.getAttribute('content') || '').replace(/\/$/, '');

  async function loadIndex() {
    if (searchIndex) return searchIndex;
    try {
      const res = await fetch(`${BASE}/search-index.json`);
      searchIndex = await res.json();
      return searchIndex!;
    } catch {
      return [];
    }
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function createResultItem(m: { l: string; n: string; t: string; u: string }): HTMLLIElement {
    const li = document.createElement('li');
    const a = document.createElement('a');
    a.href = `${BASE}/${m.l.toLowerCase()}/${m.u}`;

    const lawSpan = document.createElement('span');
    lawSpan.className = 'sr-law';
    lawSpan.textContent = m.l;

    const numSpan = document.createElement('span');
    numSpan.className = 'sr-num';
    numSpan.textContent = `Art.\u00a0${m.n}`;

    const titleSpan = document.createElement('span');
    titleSpan.className = 'sr-title';
    titleSpan.textContent = m.t;

    a.appendChild(lawSpan);
    a.appendChild(numSpan);
    a.appendChild(titleSpan);
    li.appendChild(a);
    return li;
  }

  async function search(query: string) {
    const index = await loadIndex();
    if (!query.trim()) {
      results.hidden = true;
      return;
    }

    const q = query.toLowerCase().trim();
    // Parse "art 41 or" pattern
    const artMatch = q.match(/^art\.?\s*(\d+\w*)\s+(\w+)$/i);

    let matches: typeof index;
    if (artMatch) {
      const num = artMatch[1].toLowerCase();
      const law = artMatch[2].toLowerCase();
      matches = index.filter((a) => a.n.toLowerCase() === num && a.l.toLowerCase() === law);
    } else {
      matches = index.filter((a) => {
        const artNum = `art. ${a.n} ${a.l}`.toLowerCase();
        const artNum2 = `art ${a.n} ${a.l}`.toLowerCase();
        const full = `${a.l} ${a.n} ${a.t}`.toLowerCase();
        return full.includes(q) || artNum.includes(q) || artNum2.includes(q);
      });
    }

    matches = matches.slice(0, 12);
    activeIndex = -1;

    if (matches.length === 0) {
      resultsList.replaceChildren();
      emptyEl.hidden = false;
      results.hidden = false;
      return;
    }

    emptyEl.hidden = true;
    const fragment = document.createDocumentFragment();
    for (const m of matches) {
      fragment.appendChild(createResultItem(m));
    }
    resultsList.replaceChildren(fragment);
    results.hidden = false;
  }

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => search(input.value), 120);
  });

  input?.addEventListener('focus', () => {
    if (kbdEl) kbdEl.hidden = true;
    if (input.value.trim()) search(input.value);
  });

  input?.addEventListener('blur', () => {
    setTimeout(() => {
      results.hidden = true;
      if (kbdEl && !input.value) kbdEl.hidden = false;
    }, 200);
  });

  input?.addEventListener('keydown', (e) => {
    const items = resultsList.querySelectorAll('a');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      items.forEach((a, i) => a.classList.toggle('active', i === activeIndex));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, 0);
      items.forEach((a, i) => a.classList.toggle('active', i === activeIndex));
    } else if (e.key === 'Enter' && activeIndex >= 0 && items[activeIndex]) {
      e.preventDefault();
      (items[activeIndex] as HTMLAnchorElement).click();
    } else if (e.key === 'Escape') {
      results.hidden = true;
      input.blur();
    }
  });

  // Global "/" shortcut
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !['INPUT', 'TEXTAREA', 'SELECT'].includes((e.target as Element)?.tagName)) {
      e.preventDefault();
      input?.focus();
    }
  });
</script>
