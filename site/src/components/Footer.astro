---
// site/src/components/Footer.astro
import { type Lang, t } from '@/lib/i18n';
import { langBase } from '@/lib/base';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner page-wrapper">
    <div>Quelle: <a href="https://opencaselaw.ch">OpenCaseLaw.ch</a> · Inhalt: CC0 · Code: MIT</div>
    <div class="footer-right">
      <a href={`${langBase(lang)}/support`}>{t('support.title', lang)}</a>
      <span class="footer-dot">·</span>
      <span>openlegalcommentary.ch</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    padding: var(--space-3) 0;
    margin-top: auto;
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .footer-dot {
    margin: 0 6px;
  }

  .site-footer a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .site-footer a:hover {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
