---
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase } from '@/lib/base';
import { renderMarkdown } from '@/lib/markdown';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { listContested, loadContested } from '../../../lib/content';

export function getStaticPaths() {
  const pages = listContested();
  return LANGS.flatMap(lang =>
    pages.map(p => ({ params: { lang, slug: p.slug } }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const page = loadContested(slug!);
if (!page) return Astro.redirect(`/${lang}/contested`);

const { html: contentHtml } = renderMarkdown(page.content, lang);

function provisionToLink(prov: string): { href: string; label: string } {
  const [law, art] = prov.split('/');
  const num = art.replace('art-', '').replace(/^0+/, '');
  return {
    href: `${langBase(lang)}/${law}/art-${num}`,
    label: `Art. ${num} ${law.toUpperCase()}`,
  };
}
---

<Base title={page.meta.title} lang={lang} pagePath={`/contested/${slug}`}>
  <Breadcrumb
    lang={lang}
    items={[
      { label: t('nav.contested', lang), href: `${langBase(lang)}/contested` },
      { label: page.meta.title },
    ]}
  />

  <article class="page-wrapper" data-pagefind-body data-pagefind-filter={`language:${lang}`}>
    <div class="page-grid">
      <div class="left-col">
        <div class="label">{t('contested.type', lang) || 'Contested Question'}</div>
        <h1 class="contested-title">{page.meta.title}</h1>

        <div class="meta-block">
          <div class="label">{t('contested.question', lang)}</div>
          <p class="question-text">{page.meta.question}</p>
        </div>

        <div class="meta-block">
          <div class="label">{t('contested.positions', lang)}</div>
          {page.meta.positions.map((pos, i) => (
            <div class="position-entry">
              <span class="position-letter">{String.fromCharCode(65 + i)}.</span>
              <div class="position-body">
                <span class="position-label">{pos.label}</span>
                <span class="position-summary">{pos.summary}</span>
              </div>
            </div>
          ))}
        </div>

        {page.meta.provisions.length > 0 && (
          <div class="meta-block">
            <div class="label">{t('concepts.provisions', lang)}</div>
            <ul class="provision-list">
              {page.meta.provisions.map(prov => {
                const link = provisionToLink(prov);
                return <li><a href={link.href}>{link.label}</a></li>;
              })}
            </ul>
          </div>
        )}

        <div class="meta-block">
          <div class="label">{page.meta.author_status}</div>
        </div>
      </div>

      <div class="right-col">
        <div class="contested-content prose" set:html={contentHtml} />
      </div>
    </div>
  </article>
</Base>

<style>
  .contested-title {
    font-family: var(--font-ui);
    font-size: 24px;
    font-weight: 700;
    margin: var(--space-1) 0 var(--space-4);
    line-height: 1.2;
  }

  .meta-block {
    margin-bottom: var(--space-3);
  }

  .question-text {
    font-family: var(--font-body);
    font-size: 14px;
    font-style: italic;
    color: var(--color-text);
    margin: 4px 0 0;
    line-height: 1.5;
  }

  .position-entry {
    display: flex;
    gap: var(--space-1);
    padding: 8px 0;
    border-bottom: 1px solid var(--color-rule-light);
  }

  .position-entry:first-of-type {
    border-top: 1px solid var(--color-rule-light);
    margin-top: 4px;
  }

  .position-letter {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12px;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .position-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .position-label {
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text);
  }

  .position-summary {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .provision-list {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .provision-list a {
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule-light);
    padding-bottom: 1px;
    transition: border-color var(--transition-fast);
  }

  .provision-list a:hover {
    border-bottom-color: var(--color-rule);
  }

  .contested-content {
    line-height: 1.7;
  }
</style>
