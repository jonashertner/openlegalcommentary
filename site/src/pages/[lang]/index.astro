---
// site/src/pages/[lang]/index.astro
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase, langHome } from '@/lib/base';
import Base from '../../layouts/Base.astro';
import LawCard from '../../components/LawCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import { LAWS } from '../../lib/laws';
import { getLawStats } from '../../lib/content';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const lawsWithStats = LAWS.map((law) => ({
  law,
  stats: getLawStats(law.abbr),
}));

const totalArticles = lawsWithStats.reduce((sum, l) => sum + l.stats.totalArticles, 0);
---

<Base title="Home" lang={lang} pagePath="/">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow animate-fade-up font-heading">{t('home.eyebrow', lang)}</p>
      <h1 class="hero-title animate-fade-up delay-1">
        <span class="display-font">Open Legal</span><br />
        <span class="display-font display-italic">Commentary</span>
      </h1>
      <span class="accent-line-wide delay-2"></span>
      <p class="hero-description animate-fade-up delay-3">
        {t('home.subtitle', lang)}
      </p>
      <div class="hero-search animate-fade-up delay-4">
        <SearchBar />
      </div>
      <div class="hero-stats animate-fade-up delay-5">
        <div class="hero-stat">
          <span class="hero-stat-value">{LAWS.length}</span>
          <span class="hero-stat-label">{t('home.stat.laws', lang)}</span>
        </div>
        <span class="hero-stat-divider" aria-hidden="true"></span>
        <div class="hero-stat">
          <span class="hero-stat-value">{totalArticles.toLocaleString('de-CH')}</span>
          <span class="hero-stat-label">{t('home.stat.articles', lang)}</span>
        </div>
        <span class="hero-stat-divider" aria-hidden="true"></span>
        <div class="hero-stat">
          <span class="hero-stat-value">3</span>
          <span class="hero-stat-label">{t('home.stat.layers', lang)}</span>
        </div>
        <span class="hero-stat-divider" aria-hidden="true"></span>
        <div class="hero-stat">
          <span class="hero-stat-value">{LANGS.length}</span>
          <span class="hero-stat-label">{t('home.stat.languages', lang)}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Laws Grid -->
  <section class="laws-section" aria-label={t('home.laws_heading', lang)}>
    <div class="laws-header animate-fade-up delay-6">
      <h2>{t('home.laws_heading', lang)}</h2>
      <p class="text-secondary text-sm">{LAWS.length} {t('home.stat.laws', lang)}</p>
    </div>
    <div class="laws-grid">
      {lawsWithStats.map(({ law, stats }, i) => (
        <div class={`animate-scale-in delay-${Math.min(i + 3, 8)}`}>
          <LawCard lang={lang} law={law} stats={stats} />
        </div>
      ))}
    </div>
  </section>

  <!-- Layers Explanation -->
  <section class="layers-section">
    <div class="layers-header animate-fade-up">
      <h2>{t('home.layers_heading', lang)}</h2>
    </div>
    <div class="layers-grid">
      <div class="layer-card animate-fade-up delay-1">
        <div class="layer-number" aria-hidden="true">01</div>
        <h3>{t('home.layer1.title', lang)}</h3>
        <p>{t('home.layer1.desc', lang)}</p>
      </div>
      <div class="layer-card animate-fade-up delay-2">
        <div class="layer-number" aria-hidden="true">02</div>
        <h3>{t('home.layer2.title', lang)}</h3>
        <p>{t('home.layer2.desc', lang)}</p>
      </div>
      <div class="layer-card animate-fade-up delay-3">
        <div class="layer-number" aria-hidden="true">03</div>
        <h3>{t('home.layer3.title', lang)}</h3>
        <p>{t('home.layer3.desc', lang)}</p>
      </div>
    </div>
  </section>

  <!-- Open Access Banner -->
  <section class="open-section animate-fade-up">
    <div class="open-inner">
      <h2 class="display-font">{t('home.open_heading', lang)}</h2>
      <p>{t('home.open_desc', lang)}</p>
      <div class="open-links">
        <a href="https://github.com/jonashertner/openlegalcommentary" target="_blank" rel="noopener" class="open-link">
          <span class="open-link-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </span>
          GitHub
        </a>
        <a href="https://huggingface.co/datasets/openlegalcommentary/swiss-law-commentary" target="_blank" rel="noopener" class="open-link">
          <span class="open-link-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </span>
          HuggingFace Dataset
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== Hero ===== */
  .hero {
    padding: var(--space-10) 0 var(--space-8);
    position: relative;
  }

  .hero-content {
    max-width: 680px;
  }

  .hero-eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .hero-title {
    font-size: var(--text-hero);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-3);
  }

  .hero-description {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin-top: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .hero-search {
    margin-bottom: var(--space-4);
    position: relative;
    z-index: 10;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-stat-value {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-text);
  }

  .hero-stat-label {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-stat-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border);
  }

  /* ===== Laws Section ===== */
  .laws-section {
    padding-bottom: var(--space-8);
  }

  .laws-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .laws-header h2 {
    font-size: var(--text-lg);
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .laws-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  /* ===== Layers Section ===== */
  .layers-section {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
  }

  .layers-header {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .layers-header h2 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-1);
  }

  .layers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .layer-card {
    padding: var(--space-4);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .layer-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .layer-number {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-3xl);
    color: var(--color-border);
    line-height: 1;
    margin-bottom: var(--space-2);
    letter-spacing: -0.03em;
  }

  .layer-card:hover .layer-number {
    color: var(--color-accent);
    transition: color var(--transition-base);
  }

  .layer-card h3 {
    font-size: var(--text-md);
    font-weight: 700;
    margin: 0 0 var(--space-1) 0;
  }

  .layer-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ===== Open Access Section ===== */
  .open-section {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
  }

  .open-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .open-inner h2 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-2);
  }

  .open-inner > p {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .open-links {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
  }

  .open-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 8px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .open-link:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
    background: var(--color-bg-alt);
  }

  .open-link-icon {
    display: flex;
    align-items: center;
    opacity: 0.6;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .laws-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-6) 0 var(--space-5);
    }

    .hero-stats {
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .hero-stat-divider {
      display: none;
    }

    .hero-stat {
      flex-direction: row;
      align-items: baseline;
      gap: 6px;
    }

    .hero-stat-value {
      font-size: var(--text-xl);
    }

    .laws-grid {
      grid-template-columns: 1fr;
    }

    .layers-grid {
      grid-template-columns: 1fr;
    }

    .open-links {
      flex-direction: column;
      align-items: center;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }
    .hero-stats {
      gap: var(--space-2);
    }
    .hero-stat-value {
      font-size: var(--text-lg);
    }
  }
</style>
