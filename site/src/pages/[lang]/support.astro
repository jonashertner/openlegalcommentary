---
// site/src/pages/[lang]/support.astro
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase } from '@/lib/base';
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
---

<Base title={t('support.title', lang)} lang={lang} pagePath="/support" description={t('support.meta', lang)}>
  <article class="support-page">
    <div class="page-wrapper">

      <!-- Hero -->
      <section class="support-hero">
        <div class="support-tag">{t('support.tag', lang)}</div>
        <h1 class="support-title">{t('support.headline', lang)}</h1>
        <p class="support-lead">{t('support.lead', lang)}</p>
      </section>

      <!-- Pipeline -->
      <section class="support-section">
        <h2>{t('support.pipeline_title', lang)}</h2>
        <div class="pipeline">
          <div class="pipeline-step">
            <div class="step-num">1</div>
            <div class="step-body">
              <div class="step-label">{t('support.step1_label', lang)}</div>
              <p class="step-desc">{t('support.step1_desc', lang)}</p>
            </div>
          </div>
          <div class="pipeline-step">
            <div class="step-num">2</div>
            <div class="step-body">
              <div class="step-label">{t('support.step2_label', lang)}</div>
              <p class="step-desc">{t('support.step2_desc', lang)}</p>
            </div>
          </div>
          <div class="pipeline-step">
            <div class="step-num">3</div>
            <div class="step-body">
              <div class="step-label">{t('support.step3_label', lang)}</div>
              <p class="step-desc">{t('support.step3_desc', lang)}</p>
            </div>
          </div>
          <div class="pipeline-step">
            <div class="step-num">4</div>
            <div class="step-body">
              <div class="step-label">{t('support.step4_label', lang)}</div>
              <p class="step-desc">{t('support.step4_desc', lang)}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- The Prompt -->
      <section class="support-section">
        <h2>{t('support.prompt_title', lang)}</h2>
        <p>{t('support.prompt_intro', lang)}</p>
        <div class="prompt-window">
          <div class="prompt-header">
            <span class="prompt-dot"></span>
            <span class="prompt-dot"></span>
            <span class="prompt-dot"></span>
            <span class="prompt-filename">doctrine_prompt.txt</span>
          </div>
          <pre class="prompt-code"><span class="prompt-section">Requirements:</span>
- Use numbered marginal notes: <span class="prompt-hl">N. 1</span>, <span class="prompt-hl">N. 2</span>, etc.
- Required sections, in order:
  1. Entstehungsgeschichte (legislative history)
  2. Systematische Einordnung (systematic context)
  3. Tatbestandsmerkmale / Norminhalt (elements)
  4. Rechtsfolgen (legal consequences)
  5. Streitstände (doctrinal debates)
  6. Praxishinweise (practical guidance)
- Minimum 3 secondary sources from different authors
- Cross-references use arrow notation: &rarr; / &harr;

<span class="prompt-section">Citation style:</span>
Cite scholarly authors in <span class="prompt-hl">literature format</span> by default:
  Häfelin/Haller/Keller/Thurnherr, Schweizerisches
  Bundesstaatsrecht, 10. Aufl. 2020, N 749

Use BSK/CR format <span class="prompt-hl">only</span> when the cited author
appears in the reference data block. Do not invent
BSK author/Randziffer combinations.

<span class="prompt-section">Konzision discipline:</span>
Each Randziffer must contribute <span class="prompt-hl">new content</span>.
Do not restate a holding across two different N.s.

<span class="prompt-section">When Materialien are provided:</span>
- Cite with exact BBl page references
- Attribute statements to <span class="prompt-hl">named speakers</span>
- Note what was contested in parliament
- ONLY cite specifics that appear in the
  Materialien block — do <span class="prompt-hl">not fabricate</span></pre>
        </div>
      </section>

      <!-- Example result -->
      <section class="support-section">
        <h2>{t('support.example_title', lang)}</h2>
        <p>{t('support.example_intro', lang)}</p>
        <div class="example-link">
          <a href={`${langBase(lang)}/bv/art-8?layer=doctrine`}>
            {t('support.example_cta', lang)} &rarr;
          </a>
        </div>
      </section>

      <!-- Cost -->
      <section class="support-section">
        <h2>{t('support.cost_title', lang)}</h2>
        <p>{t('support.cost_intro', lang)}</p>
        <div class="cost-grid">
          <div class="cost-row"><span>{t('support.cost_gen', lang)}</span><span>CHF 1.50</span></div>
          <div class="cost-row"><span>{t('support.cost_eval', lang)}</span><span>CHF 1.00</span></div>
          <div class="cost-row"><span>{t('support.cost_trans', lang)}</span><span>CHF 0.80</span></div>
          <div class="cost-row"><span>{t('support.cost_mat', lang)}</span><span>CHF 0.20</span></div>
          <div class="cost-row"><span>{t('support.cost_retry', lang)}</span><span>CHF 1.00</span></div>
          <div class="cost-row"><span>{t('support.cost_reserve', lang)}</span><span>CHF 1.50</span></div>
          <div class="cost-row cost-total"><span>Total</span><span>CHF 6.00</span></div>
        </div>
        <p class="cost-note">{t('support.cost_note', lang)}</p>
      </section>

      <!-- Scale -->
      <section class="support-section">
        <h2>{t('support.scale_title', lang)}</h2>
        <table class="support-table">
          <thead>
            <tr>
              <th>{t('support.col_law', lang)}</th>
              <th>{t('support.col_articles', lang)}</th>
              <th>{t('support.col_target', lang)}</th>
              <th>{t('support.col_status', lang)}</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>BV</td><td>233</td><td>CHF 1'500</td><td class="status-progress">{t('support.status_progress', lang)}</td></tr>
            <tr><td>BGFA</td><td>38</td><td>CHF 250</td><td class="status-progress">{t('support.status_progress', lang)}</td></tr>
            <tr><td>VwVG</td><td>92</td><td>CHF 600</td><td class="status-open">{t('support.status_open', lang)}</td></tr>
            <tr><td>SchKG</td><td>400</td><td>CHF 2'500</td><td class="status-open">{t('support.status_open', lang)}</td></tr>
            <tr><td>ZPO</td><td>426</td><td>CHF 2'700</td><td class="status-open">{t('support.status_open', lang)}</td></tr>
            <tr><td>StGB</td><td>466</td><td>CHF 3'000</td><td class="status-open">{t('support.status_open', lang)}</td></tr>
            <tr><td>StPO</td><td>478</td><td>CHF 3'000</td><td class="status-open">{t('support.status_open', lang)}</td></tr>
            <tr><td>ZGB</td><td>1'126</td><td>CHF 7'000</td><td class="status-open">{t('support.status_open', lang)}</td></tr>
            <tr><td>OR</td><td>1'584</td><td>CHF 10'000</td><td class="status-open">{t('support.status_open', lang)}</td></tr>
            <tr class="total-row"><td><strong>Total</strong></td><td><strong>4'843</strong></td><td><strong>CHF 30'550</strong></td><td></td></tr>
          </tbody>
        </table>
      </section>

      <!-- Independence -->
      <section class="support-section support-independence">
        <h2>{t('support.independence_title', lang)}</h2>
        <p>{t('support.independence_text', lang)}</p>
      </section>

      <!-- Donate -->
      <section class="support-section support-donate" id="donate">
        <h2>{t('support.donate_title', lang)}</h2>
        <div class="donate-methods">
          <div class="donate-method">
            <h3>TWINT</h3>
            <p class="donate-note">{t('support.donate_twint', lang)}</p>
            <div class="donate-placeholder">[QR Code]</div>
          </div>
          <div class="donate-method">
            <h3>{t('support.donate_bank_title', lang)}</h3>
            <p class="donate-note">{t('support.donate_bank', lang)}</p>
            <div class="donate-placeholder">[IBAN]</div>
          </div>
          <div class="donate-method">
            <h3>GitHub Sponsors</h3>
            <p class="donate-note">{t('support.donate_github', lang)}</p>
          </div>
        </div>
      </section>

      <!-- Supporters -->
      <section class="support-section">
        <h2>{t('support.supporters_title', lang)}</h2>
        <p>{t('support.supporters_intro', lang)}</p>
        <p class="support-cta">{t('support.supporters_cta', lang)}</p>
      </section>

    </div>
  </article>
</Base>

<style>
  .support-page {
    padding-bottom: var(--space-8);
  }

  .support-hero {
    padding: var(--space-8) 0 var(--space-6);
    border-bottom: 1px solid var(--color-rule);
  }

  .support-tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #DC2626;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .support-title {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 700px;
  }

  .support-lead {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin-top: var(--space-4);
  }

  .support-section {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-rule-light);
  }

  .support-section h2 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  .support-section p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 640px;
    margin-bottom: var(--space-2);
  }

  /* Pipeline */
  .pipeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-rule-light);
    border: 1px solid var(--color-rule);
    margin-top: var(--space-4);
  }

  .pipeline-step {
    background: var(--color-bg);
    padding: var(--space-3);
  }

  .step-num {
    font-size: 32px;
    font-weight: 700;
    color: var(--color-text-muted);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .step-label {
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .step-desc {
    font-size: 12px !important;
    line-height: 1.5 !important;
    color: var(--color-text-muted) !important;
    margin-bottom: 0 !important;
    max-width: none !important;
  }

  /* Prompt window */
  .prompt-window {
    margin-top: var(--space-3);
    border: 1px solid var(--color-rule);
    overflow: hidden;
    max-width: 640px;
  }

  .prompt-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: var(--color-rule-light);
    border-bottom: 1px solid var(--color-rule);
  }

  .prompt-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-text-muted);
    opacity: 0.3;
  }

  .prompt-filename {
    font-size: 11px;
    color: var(--color-text-muted);
    margin-left: 6px;
  }

  .prompt-code {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', Menlo, Monaco, Consolas, monospace;
    font-size: 11.5px;
    line-height: 1.6;
    padding: var(--space-3);
    margin: 0;
    overflow-x: auto;
    color: var(--color-text-secondary);
    white-space: pre;
    tab-size: 2;
  }

  .prompt-section {
    color: var(--color-text);
    font-weight: 600;
  }

  .prompt-hl {
    color: #DC2626;
    font-weight: 600;
  }

  :global([data-theme='dark']) .prompt-hl {
    color: #F87171;
  }

  /* Example */
  .example-link {
    margin-top: var(--space-3);
    padding: var(--space-3);
    border: 1px solid var(--color-rule);
  }

  .example-link a {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .example-link a:hover {
    text-decoration: underline;
  }

  /* Cost grid */
  .cost-grid {
    max-width: 360px;
    margin-top: var(--space-3);
  }

  .cost-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    border-bottom: 1px solid var(--color-rule-light);
    font-size: 13px;
  }

  .cost-row span:first-child {
    color: var(--color-text-secondary);
  }

  .cost-row span:last-child {
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
  }

  .cost-total {
    border-top: 1px solid var(--color-rule);
    border-bottom: none;
    padding-top: var(--space-2);
    font-weight: 700;
  }

  .cost-total span:first-child,
  .cost-total span:last-child {
    color: var(--color-text);
  }

  .cost-note {
    font-size: 11px !important;
    color: var(--color-text-muted) !important;
    margin-top: var(--space-2) !important;
  }

  /* Table */
  .support-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin-top: var(--space-3);
  }

  .support-table th {
    text-align: left;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-2);
    border-bottom: 1px solid var(--color-rule);
  }

  .support-table td {
    padding: var(--space-1) var(--space-2);
    border-bottom: 1px solid var(--color-rule-light);
  }

  .total-row td {
    border-top: 1px solid var(--color-rule);
    border-bottom: none;
    padding-top: var(--space-2);
  }

  .status-progress {
    color: #DC2626;
    font-weight: 600;
    font-size: 11px;
  }

  .status-open {
    color: var(--color-text-muted);
    font-size: 11px;
  }

  /* Independence */
  .support-independence p {
    font-size: 15px !important;
    color: var(--color-text) !important;
    font-weight: 500;
  }

  /* Donate */
  .support-donate {
    border-bottom: none;
  }

  .donate-methods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .donate-method {
    padding: var(--space-3);
    border: 1px solid var(--color-rule);
  }

  .donate-method h3 {
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 var(--space-1);
  }

  .donate-note {
    font-size: 12px !important;
    color: var(--color-text-muted) !important;
  }

  .donate-placeholder {
    margin-top: var(--space-2);
    padding: var(--space-4);
    background: var(--color-rule-light);
    text-align: center;
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .support-cta {
    font-size: 15px !important;
    font-weight: 600;
    color: var(--color-text) !important;
  }

  @media (max-width: 768px) {
    .support-title { font-size: 28px; }
    .pipeline { grid-template-columns: 1fr; }
    .donate-methods { grid-template-columns: 1fr; }
  }
</style>
