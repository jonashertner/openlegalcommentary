---
// site/src/pages/[lang]/[law]/[article].astro
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase, langHome } from '@/lib/base';
import { renderMarkdown, type TocEntry } from '@/lib/markdown';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ArticleTabs from '../../../components/ArticleTabs.astro';
import ArticlePagination from '../../../components/ArticlePagination.astro';
import Gesetzestext from '../../../components/Gesetzestext.astro';
import { LAWS, getLawByAbbr } from '../../../lib/laws';
import { listArticleDirs, listArticles, loadArticle, slugToDirName, getArticleNav, getArticleText, getTranslatedTitle } from '../../../lib/content';

export function getStaticPaths() {
  const laws = ['bv', 'zgb', 'or', 'zpo', 'stgb', 'stpo', 'schkg', 'vwvg'];
  return LANGS.flatMap(lang =>
    laws.flatMap(law => {
      const dirs = listArticleDirs(law);
      return dirs.map(dir => {
        const match = dir.match(/^art-(\d+)([a-z]*)$/);
        const slug = match ? `art-${parseInt(match[1], 10)}${match[2] || ''}` : dir;
        return { params: { lang, law, article: slug } };
      });
    })
  );
}

const { lang, law: lawParam, article: articleSlug } = Astro.params as { lang: Lang; law: string; article: string };
const lawInfo = getLawByAbbr(lawParam!);
if (!lawInfo) return Astro.redirect(langHome(lang));

const dirName = slugToDirName(articleSlug!);
const articleData = loadArticle(lawInfo.abbr, dirName, lang);

// Build meta from article_lists.json fallback if no content dir
const allArticles = listArticles(lawInfo.abbr);
const articleEntry = allArticles.find((a) => a.slug === articleSlug);
if (!articleData && !articleEntry) return Astro.redirect(`${langBase(lang)}/${lawParam}`);

const meta = articleData?.meta || articleEntry!.meta;
const summary = articleData?.summary || '';
const doctrine = articleData?.doctrine || '';
const caselaw = articleData?.caselaw || '';
const rawNav = getArticleNav(lawInfo.abbr, dirName);
// Translate prev/next titles
const nav = {
  prev: rawNav.prev ? { slug: rawNav.prev.slug, title: getTranslatedTitle(lawInfo.abbr, rawNav.prev.slug.replace('art-', ''), lang, rawNav.prev.title) } : null,
  next: rawNav.next ? { slug: rawNav.next.slug, title: getTranslatedTitle(lawInfo.abbr, rawNav.next.slug.replace('art-', ''), lang, rawNav.next.title) } : null,
};

// Load Gesetzestext in the current language, fallback to German
const articleRaw = `${meta.article}${meta.article_suffix || ''}`;
let gesetzestextParagraphs = getArticleText(lawInfo.abbr, articleRaw, lang);
if (gesetzestextParagraphs.length === 0 && lang !== 'de') {
  gesetzestextParagraphs = getArticleText(lawInfo.abbr, articleRaw, 'de');
}

// Translate article title if available
const translatedTitle = getTranslatedTitle(lawInfo.abbr, articleRaw, lang, meta.title);

const { html: summaryHtml } = renderMarkdown(summary, lang);
const { html: doctrineHtml, toc: doctrineToc } = renderMarkdown(doctrine, lang);
const { html: caselawHtml, toc: caselawToc } = renderMarkdown(caselaw, lang);

const isPreamble = meta.article === 0;
const articleDisplay = isPreamble
  ? `${translatedTitle} ${lawInfo.abbr}`
  : `Art. ${meta.article}${meta.article_suffix || ''} ${lawInfo.abbr}`;

const layerParam = Astro.url.searchParams.get('layer') || 'summary';
const activeTab = ['summary', 'doctrine', 'caselaw'].includes(layerParam) ? layerParam : 'summary';

const layerMeta = meta.layers || {};
const lastUpdated = Object.values(layerMeta)
  .map((l: any) => l.last_generated)
  .filter(Boolean)
  .sort()
  .pop();

// Generate per-article meta description from summary first sentence
const summaryPlain = summary.replace(/[#*>\[\]()]/g, '').replace(/\n+/g, ' ').trim();
const firstSentence = summaryPlain.match(/^.{50,200}?[.!?]\s/)?.[0]?.trim() || summaryPlain.slice(0, 160);
const metaDescription = firstSentence || `${t('footer.commentary', lang)}: ${articleDisplay} — ${translatedTitle}`;
---

<Base title={`${articleDisplay} — ${translatedTitle}`} lang={lang} pagePath={`/${lawParam}/${articleSlug}`} description={metaDescription}>
  <meta name="citation_title" content={`${articleDisplay} — ${translatedTitle}`} />
  <meta name="citation_author" content="Open Legal Commentary" />
  <meta name="citation_publication_date" content={(lastUpdated || '').replace(/-/g, '/')} />
  <meta name="citation_journal_title" content="Open Legal Commentary" />
  <meta name="citation_volume" content={lawInfo.abbr} />
  <meta name="citation_language" content={lang} />
  <meta name="citation_fulltext_html_url" content={`https://openlegalcommentary.ch${langBase(lang)}/${lawParam}/${articleSlug}`} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ScholarlyArticle",
    "headline": `${articleDisplay} — ${translatedTitle}`,
    "description": metaDescription,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Open Legal Commentary",
      "url": "https://openlegalcommentary.ch"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Open Legal Commentary",
      "url": "https://openlegalcommentary.ch"
    },
    "author": {
      "@type": "Organization",
      "name": "Open Legal Commentary"
    },
    "about": {
      "@type": "Legislation",
      "name": lawInfo.name[lang],
      "legislationIdentifier": `SR ${meta.sr_number} Art. ${meta.article}${meta.article_suffix || ''}`,
      "jurisdiction": {
        "@type": "AdministrativeArea",
        "name": "Switzerland"
      }
    },
    "datePublished": Object.values(layerMeta).map((l: any) => l.last_generated).filter(Boolean).sort()[0] || undefined,
    "dateModified": lastUpdated || undefined,
    "license": "https://creativecommons.org/licenses/by-sa/4.0/",
    "keywords": `Swiss law, ${lawInfo.name[lang]}, Art. ${meta.article}${meta.article_suffix || ''}, legal commentary`
  })} />
  <Breadcrumb
    lang={lang}
    items={[
      { label: lawInfo.abbr, href: `${langBase(lang)}/${lawParam}` },
      { label: articleDisplay },
    ]}
  />

  <article class="article-page content-column" data-pagefind-body data-pagefind-filter={`language:${lang}`} data-pagefind-meta={`law:${lawParam!.toUpperCase()}, article:${meta.article}${meta.article_suffix || ''}`}>
    <header class="article-header">
      <h1>{translatedTitle}</h1>
      <div class="article-meta text-sm text-muted">
        <span class="font-mono">SR {meta.sr_number}</span>
        {meta.in_force_since && (
          <span>{t('article.in_force_since', lang)} {meta.in_force_since}</span>
        )}
      </div>
    </header>

    <Gesetzestext
      paragraphs={gesetzestextParagraphs}
      lang={lang}
      articleDisplay={articleDisplay}
      fedlexUrl={meta.fedlex_url}
    />

    <ArticleTabs
      lang={lang}
      summary={summaryHtml}
      doctrine={doctrineHtml}
      caselaw={caselawHtml}
      activeTab={activeTab}
      doctrineToc={doctrineToc}
      caselawToc={caselawToc}
    />

    {lastUpdated && (
      <p class="article-updated text-xs text-muted">
        {t('article.last_updated', lang)}: {lastUpdated}
      </p>
    )}

    <ArticlePagination
      lang={lang}
      law={lawParam!}
      prev={nav.prev}
      next={nav.next}
    />
  </article>

  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <!-- Back to top -->
  <button
    class="back-to-top"
    id="back-to-top"
    aria-label={t('article.back_to_top', lang)}
    title={t('article.back_to_top', lang)}
  >
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <path d="M9 14V4M9 4L4 9M9 4l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</Base>

<style>
  .article-page {
    padding-top: var(--space-2);
  }

  .article-header {
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border-light);
  }

  .article-header h1 {
    margin-bottom: var(--space-1);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .fedlex-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-xs);
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .fedlex-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .article-updated {
    margin-top: var(--space-3);
    text-align: right;
  }

  /* Reading progress bar */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: var(--gradient-accent);
    z-index: 1000;
    width: 0%;
    transition: width 50ms linear;
    pointer-events: none;
  }

  /* Back to top button */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity var(--transition-base), transform var(--transition-base),
      color var(--transition-fast), border-color var(--transition-fast),
      box-shadow var(--transition-fast);
    pointer-events: none;
    box-shadow: var(--shadow-sm);
    z-index: 100;
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .back-to-top {
      bottom: 1rem;
      right: 1rem;
      width: 36px;
      height: 36px;
    }
    .article-meta {
      flex-direction: column;
      gap: var(--space-1);
    }
    .article-updated {
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .article-header h1 {
      font-size: 1.25rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // Reading progress bar
    function updateProgress() {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = `${Math.min(progress, 100)}%`;
    }

    // Back to top button
    function updateBackToTop() {
      const btn = document.getElementById('back-to-top');
      if (!btn) return;
      btn.classList.toggle('visible', window.scrollY > 400);
    }

    window.addEventListener('scroll', () => {
      requestAnimationFrame(() => {
        updateProgress();
        updateBackToTop();
      });
    }, { passive: true });

    document.getElementById('back-to-top')?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
