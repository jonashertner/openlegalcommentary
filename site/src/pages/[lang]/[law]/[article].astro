---
// site/src/pages/[lang]/[law]/[article].astro
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase, langHome } from '@/lib/base';
import { renderMarkdown, type TocEntry } from '@/lib/markdown';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ArticleTabs from '../../../components/ArticleTabs.astro';
import ArticlePagination from '../../../components/ArticlePagination.astro';
import Gesetzestext from '../../../components/Gesetzestext.astro';
import { LAWS, getLawByAbbr } from '../../../lib/laws';
import { listArticleDirs, listArticles, loadArticle, slugToDirName, getArticleNav, getArticleText, getTranslatedTitle, getCrossReferences, listCantonalLawSlugs } from '../../../lib/content';

export function getStaticPaths() {
  const federalSlugs = LAWS.map(l => l.slug);
  const cantonalSlugs = listCantonalLawSlugs();
  const allSlugs = [...federalSlugs, ...cantonalSlugs];
  return LANGS.flatMap(lang =>
    allSlugs.flatMap(law => {
      const dirs = listArticleDirs(law);
      if (dirs.length > 0) {
        return dirs.map(dir => {
          const match = dir.match(/^art-(\d+)([a-z]*)$/);
          const slug = match ? `art-${parseInt(match[1], 10)}${match[2] || ''}` : dir;
          return { params: { lang, law, article: slug } };
        });
      }
      // Cantonal or article_lists.json fallback
      const articles = listArticles(law);
      return articles.map(art => ({ params: { lang, law, article: art.slug } }));
    })
  );
}

const { lang, law: lawParam, article: articleSlug } = Astro.params as { lang: Lang; law: string; article: string };
const lawInfo = getLawByAbbr(lawParam!);
if (!lawInfo) return Astro.redirect(langHome(lang));

const lawKey = lawInfo.slug;
const dirName = slugToDirName(articleSlug!);
const articleData = loadArticle(lawKey, dirName, lang);

// Build meta from article_lists.json fallback if no content dir
const allArticles = listArticles(lawKey);
const articleEntry = allArticles.find((a) => a.slug === articleSlug);
if (!articleData && !articleEntry) return Astro.redirect(`${langBase(lang)}/${lawParam}`);

const meta = articleData?.meta || articleEntry!.meta;
const summary = articleData?.summary || '';
const doctrine = articleData?.doctrine || '';
const caselaw = articleData?.caselaw || '';
const crossRefs = getCrossReferences(lawKey, dirName);
const rawNav = getArticleNav(lawKey, dirName);
// Translate prev/next titles
const nav = {
  prev: rawNav.prev ? { slug: rawNav.prev.slug, title: getTranslatedTitle(lawInfo.abbr, rawNav.prev.slug.replace('art-', ''), lang, rawNav.prev.title) } : null,
  next: rawNav.next ? { slug: rawNav.next.slug, title: getTranslatedTitle(lawInfo.abbr, rawNav.next.slug.replace('art-', ''), lang, rawNav.next.title) } : null,
};

// Load Gesetzestext in the current language, fallback to German
const articleRaw = `${meta.article}${meta.article_suffix || ''}`;
let gesetzestextParagraphs = getArticleText(lawKey, articleRaw, lang);
if (gesetzestextParagraphs.length === 0 && lang !== 'de') {
  gesetzestextParagraphs = getArticleText(lawKey, articleRaw, 'de');
}

// Translate article title if available
const translatedTitle = getTranslatedTitle(lawInfo.abbr, articleRaw, lang, meta.title);

const { html: summaryHtml } = renderMarkdown(summary, lang);
const { html: doctrineHtml, toc: doctrineToc } = renderMarkdown(doctrine, lang);
const { html: caselawHtml, toc: caselawToc } = renderMarkdown(caselaw, lang);

const isPreamble = meta.article === 0;
const articleDisplay = isPreamble
  ? `${translatedTitle} ${lawInfo.abbr}`
  : `Art. ${meta.article}${meta.article_suffix || ''} ${lawInfo.abbr}`;

const layerParam = Astro.url.searchParams.get('layer') || 'summary';
const activeTab = ['summary', 'doctrine', 'caselaw'].includes(layerParam) ? layerParam : 'summary';

const layerMeta = meta.layers || {};
const lastUpdated = Object.values(layerMeta)
  .map((l: any) => l.last_generated)
  .filter(Boolean)
  .sort()
  .pop();

// Generate per-article meta description from summary first sentence
const summaryPlain = summary.replace(/[#*>\[\]()]/g, '').replace(/\n+/g, ' ').trim();
const firstSentence = summaryPlain.match(/^.{50,200}?[.!?]\s/)?.[0]?.trim() || summaryPlain.slice(0, 160);
const metaDescription = firstSentence || `${t('footer.commentary', lang)}: ${articleDisplay} — ${translatedTitle}`;

const conceptRefs = crossRefs.filter(r => r.type === 'concept');
const showFallbackNotice = lang !== 'de' && articleData?.isFallback;
---

<Base title={`${articleDisplay} — ${translatedTitle}`} lang={lang} pagePath={`/${lawParam}/${articleSlug}`} description={metaDescription}>
  <meta name="citation_title" content={`${articleDisplay} — ${translatedTitle}`} />
  <meta name="citation_author" content="Open Legal Commentary" />
  <meta name="citation_publication_date" content={(lastUpdated || '').replace(/-/g, '/')} />
  <meta name="citation_journal_title" content="Open Legal Commentary" />
  <meta name="citation_volume" content={lawInfo.abbr} />
  <meta name="citation_language" content={lang} />
  <meta name="citation_fulltext_html_url" content={`https://openlegalcommentary.ch${langBase(lang)}/${lawParam}/${articleSlug}`} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ScholarlyArticle",
    "headline": `${articleDisplay} — ${translatedTitle}`,
    "description": metaDescription,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Open Legal Commentary",
      "url": "https://openlegalcommentary.ch"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Open Legal Commentary",
      "url": "https://openlegalcommentary.ch"
    },
    "author": {
      "@type": "Organization",
      "name": "Open Legal Commentary"
    },
    "about": {
      "@type": "Legislation",
      "name": lawInfo.name[lang],
      "legislationIdentifier": `SR ${meta.sr_number} Art. ${meta.article}${meta.article_suffix || ''}`,
      "jurisdiction": {
        "@type": "AdministrativeArea",
        "name": "Switzerland"
      }
    },
    "datePublished": Object.values(layerMeta).map((l: any) => l.last_generated).filter(Boolean).sort()[0] || undefined,
    "dateModified": lastUpdated || undefined,
    "license": "https://creativecommons.org/licenses/by-sa/4.0/",
    "keywords": `Swiss law, ${lawInfo.name[lang]}, Art. ${meta.article}${meta.article_suffix || ''}, legal commentary`
  })} />
  <Breadcrumb
    lang={lang}
    items={[
      { label: lawInfo.abbr, href: `${langBase(lang)}/${lawParam}` },
      { label: articleDisplay },
    ]}
  />

  <div class="page-grid" data-pagefind-body data-pagefind-filter={`language:${lang}`} data-pagefind-meta={`law:${lawParam!.toUpperCase()}, article:${meta.article}${meta.article_suffix || ''}`}>
    <aside class="left-col">
      <div class="label">Artikel</div>
      <div class="article-number">{meta.article}{meta.article_suffix || ''}</div>
      <div class="article-title-side">{translatedTitle}</div>

      <div class="meta-divider"></div>

      {lawInfo.canton ? (
        <>
          <div class="label">Kanton</div>
          <div class="meta-value">{lawInfo.canton}</div>
          <div class="meta-sub">{lawInfo.sr}</div>
        </>
      ) : (
        <>
          <div class="label">Gesetz</div>
          <div class="meta-value">{lawInfo.abbr.toUpperCase()}</div>
          <div class="meta-sub">SR {meta.sr_number}</div>
        </>
      )}

      {lastUpdated && (
        <>
          <div class="meta-divider"></div>
          <div class="label">{t('article.last_updated', lang)}</div>
          <div class="meta-value">{lastUpdated}</div>
        </>
      )}

      {crossRefs.length > 0 && (
        <>
          <div class="meta-divider"></div>
          <div class="label">{t('crossref.title', lang)}</div>
          <div class="cross-refs">
            {conceptRefs.map(ref => (
              <a href={`${langBase(lang)}/concepts/${ref.slug}`}>&rarr; {ref.title}</a>
            ))}
          </div>
        </>
      )}

      {meta.fedlex_url && (
        <>
          <div class="meta-divider"></div>
          <div class="label">Fedlex</div>
          <a href={meta.fedlex_url} class="meta-link" target="_blank" rel="noopener">Originaltext &rarr;</a>
        </>
      )}
    </aside>

    <div class="right-col">
      {showFallbackNotice && (
        <div class="fallback-notice">
          {t('article.fallback_notice', lang)}
        </div>
      )}
      <Gesetzestext
        paragraphs={gesetzestextParagraphs}
        lang={lang}
        articleDisplay={articleDisplay}
        fedlexUrl={meta.fedlex_url}
      />

      <ArticleTabs
        lang={lang}
        summary={summaryHtml}
        doctrine={doctrineHtml}
        caselaw={caselawHtml}
        activeTab={activeTab}
        doctrineToc={doctrineToc}
        caselawToc={caselawToc}
      />

      <ArticlePagination
        lang={lang}
        law={lawParam!}
        prev={nav.prev}
        next={nav.next}
      />
    </div>
  </div>
</Base>

<style>
  .fallback-notice {
    font-size: 12px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-rule);
    padding: 8px 12px;
    margin-bottom: var(--space-3);
    line-height: 1.5;
  }

  .article-number {
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .article-title-side {
    font-size: 13px;
    margin-top: 8px;
    line-height: 1.4;
  }

  .meta-divider {
    height: 1px;
    background: var(--color-rule-light);
    margin: var(--space-3) 0;
  }

  .meta-value {
    font-size: 12px;
  }

  .meta-sub {
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .meta-link {
    font-size: 11px;
    color: var(--color-text-secondary);
  }

  .cross-refs {
    font-size: 12px;
    line-height: 1.8;
  }

  .cross-refs a {
    display: block;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .cross-refs a:hover {
    color: var(--color-text);
  }
</style>
