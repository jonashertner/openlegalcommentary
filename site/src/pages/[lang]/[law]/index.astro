---
// site/src/pages/[lang]/[law]/index.astro
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase, langHome } from '@/lib/base';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { LAWS, getLawByAbbr } from '../../../lib/laws';
import { listArticles, getLawStats, getTranslatedTitle } from '../../../lib/content';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const laws = ['bv', 'zgb', 'or', 'zpo', 'stgb', 'stpo', 'schkg', 'vwvg', 'bgfa'];
  return LANGS.flatMap(lang =>
    laws.map(law => ({ params: { lang, law } }))
  );
}

const { lang, law: lawParam } = Astro.params as { lang: Lang; law: string };
const lawInfo = getLawByAbbr(lawParam!);

if (!lawInfo) {
  return Astro.redirect(langHome(lang));
}

const articles = listArticles(lawInfo.abbr);
const stats = getLawStats(lawInfo.abbr);

// Load structural data (Titel/Kapitel/Abschnitt) if available
interface StructureEntry {
  type: 'titel' | 'kapitel' | 'abschnitt';
  label: string;
  name: string;
  from?: number;
  to?: number;
}

let structure: StructureEntry[] = [];
let structureI18n: Record<string, string> = {};
try {
  const structPath = path.resolve('..', 'scripts', 'law_structures.json');
  const structData = JSON.parse(fs.readFileSync(structPath, 'utf-8'));
  structure = structData[lawInfo.abbr] || [];
} catch {
  // No structure data available — show flat list
}
if (lang !== 'de') {
  try {
    const i18nPath = path.resolve('..', 'scripts', 'law_structures_i18n.json');
    const i18nData = JSON.parse(fs.readFileSync(i18nPath, 'utf-8'));
    structureI18n = i18nData[lawInfo.abbr]?.[lang] || {};
  } catch {
    // No i18n data available — keep German names
  }
}

// Build a map: article number → structural headings that appear before it
const headingsBefore = new Map<number, StructureEntry[]>();

if (structure.length > 0) {
  for (const entry of structure) {
    if (entry.from != null) {
      if (!headingsBefore.has(entry.from)) {
        headingsBefore.set(entry.from, []);
      }
      headingsBefore.get(entry.from)!.push(entry);
    }
  }

  for (let i = 0; i < structure.length; i++) {
    const entry = structure[i];
    if (entry.from == null) {
      for (let j = i + 1; j < structure.length; j++) {
        if (structure[j].from != null) {
          const key = structure[j].from!;
          if (!headingsBefore.has(key)) {
            headingsBefore.set(key, []);
          }
          headingsBefore.get(key)!.unshift(entry);
          break;
        }
      }
    }
  }
}
---

<Base title={`${lawInfo.abbr} — ${lawInfo.name[lang]}`} lang={lang} pagePath={`/${lawParam}`} description={lawInfo.description[lang]}>
  <Breadcrumb lang={lang} items={[{ label: lawInfo.abbr }]} />

  <div class="page-wrapper">
    <div class="page-grid">
      <div class="left-col">
        <h1 class="law-abbr">{lawInfo.abbr}</h1>
        <p class="law-full-name">{lawInfo.name[lang]}</p>
        <p class="law-sr">SR {lawInfo.sr}</p>
        <p class="law-count">{stats.totalArticles} {t('home.stat.articles', lang)}</p>
      </div>

      <div class="right-col">
        <section class="toc">
          <ul class="toc-list">
            {articles.map((art) => {
              const suffix = art.meta.article_suffix || '';
              const displayNum = `${art.meta.article}${suffix}`;
              const hasContent = Object.keys(art.meta.layers).length > 0;
              const artNum = art.meta.article;

              const headings = headingsBefore.get(artNum) || [];

              return (
                <>
                  {headings.map((h) => {
                    const translatedLabel = h.label.replace(/Titel/, t('law.titel', lang)).replace(/Kapitel/, t('law.kapitel', lang)).replace(/Abschnitt/, t('law.abschnitt', lang));
                    return (
                      <li class="toc-heading">
                        <span class="label">{translatedLabel}</span>
                        <span class="toc-heading-name">{structureI18n[h.name] || h.name}</span>
                      </li>
                    );
                  })}
                  <li class="toc-item">
                    <a href={`${langBase(lang)}/${lawParam}/${art.slug}`}>
                      <span class="toc-num">{artNum === 0 ? '' : `Art.\u00A0${displayNum}`}</span>
                      <span class="toc-title">{getTranslatedTitle(lawInfo.abbr, `${art.meta.article}${suffix}`, lang, art.meta.title)}</span>
                    </a>
                  </li>
                </>
              );
            })}
          </ul>
        </section>
      </div>
    </div>
  </div>
</Base>

<style>
  .law-abbr {
    font-family: var(--font-ui);
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 var(--space-2);
    color: var(--color-text);
  }

  .law-full-name {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-1);
    line-height: 1.4;
  }

  .law-sr {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-1);
    letter-spacing: 0.03em;
  }

  .law-count {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* TOC */
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Structural headings */
  .toc-heading {
    padding: var(--space-3) 0 var(--space-1);
    border-bottom: 1px solid var(--color-rule);
  }

  .toc-heading .label {
    display: block;
    margin-bottom: 2px;
  }

  .toc-heading-name {
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }

  /* First heading — no extra top padding */
  .toc-list > .toc-heading:first-child {
    padding-top: 0;
  }

  /* Article items */
  .toc-item {
    border-bottom: 1px solid var(--color-rule-light);
  }

  .toc-item a {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: 10px 0;
    text-decoration: none;
    color: var(--color-text);
    font-size: 13px;
    transition: background var(--transition-fast);
  }

  .toc-item a:hover {
    background: var(--color-rule-light);
  }

  .toc-num {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 12px;
    color: var(--color-text);
    min-width: 72px;
    flex-shrink: 0;
  }

  .toc-title {
    font-family: var(--font-body);
    flex: 1;
  }

  @media (max-width: 720px) {
    .law-abbr {
      font-size: 36px;
    }
    .toc-num {
      min-width: 56px;
    }
  }
</style>
