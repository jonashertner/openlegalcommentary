---
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase } from '@/lib/base';
import { renderMarkdown } from '@/lib/markdown';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { listConcepts, loadConcept } from '../../../lib/content';

export function getStaticPaths() {
  const concepts = listConcepts();
  return LANGS.flatMap(lang =>
    concepts.map(c => ({ params: { lang, slug: c.slug } }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const concept = loadConcept(slug!);
if (!concept) return Astro.redirect(`/${lang}/concepts`);

const { html: contentHtml } = renderMarkdown(concept.content, lang);

const confidenceLabels: Record<string, string> = {
  settled: t('concepts.settled', lang),
  contested: t('concepts.contested', lang),
  evolving: t('concepts.evolving', lang),
};

function provisionToLink(prov: string): { href: string; label: string } {
  const [law, art] = prov.split('/');
  const num = art.replace('art-', '').replace(/^0+/, '');
  return {
    href: `${langBase(lang)}/${law}/art-${num}`,
    label: `Art. ${num} ${law.toUpperCase()}`,
  };
}
---

<Base title={concept.meta.title} lang={lang} pagePath={`/concepts/${slug}`}>
  <Breadcrumb
    lang={lang}
    items={[
      { label: t('nav.concepts', lang), href: `${langBase(lang)}/concepts` },
      { label: concept.meta.title },
    ]}
  />

  <article class="page-wrapper" data-pagefind-body data-pagefind-filter={`language:${lang}`}>
    <div class="page-grid">
      <div class="left-col">
        <div class="label">{t('concepts.type', lang) || 'Concept'}</div>
        <h1 class="concept-title">{concept.meta.title}</h1>

        <div class="meta-block">
          <div class="label">{t('concepts.confidence_label', lang) || 'Confidence'}</div>
          <p class="meta-value">{confidenceLabels[concept.meta.confidence]}</p>
        </div>

        <div class="meta-block">
          <div class="label">{concept.meta.author_status}</div>
        </div>

        <div class="meta-block">
          <div class="label">{t('concepts.provisions', lang)}</div>
          <ul class="provision-list">
            {concept.meta.provisions.map(prov => {
              const link = provisionToLink(prov);
              return <li><a href={link.href}>{link.label}</a></li>;
            })}
          </ul>
        </div>
      </div>

      <div class="right-col">
        <div class="concept-content prose" set:html={contentHtml} />
      </div>
    </div>
  </article>
</Base>

<style>
  .concept-title {
    font-family: var(--font-ui);
    font-size: 24px;
    font-weight: 700;
    margin: var(--space-1) 0 var(--space-4);
    line-height: 1.2;
  }

  .meta-block {
    margin-bottom: var(--space-3);
  }

  .meta-value {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text);
    margin: 4px 0 0;
  }

  .provision-list {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .provision-list a {
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule-light);
    padding-bottom: 1px;
    transition: border-color var(--transition-fast);
  }

  .provision-list a:hover {
    border-bottom-color: var(--color-rule);
  }

  .concept-content {
    line-height: 1.7;
  }
</style>
