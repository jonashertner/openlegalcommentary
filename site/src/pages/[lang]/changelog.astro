---
// site/src/pages/[lang]/changelog.astro
import { LANGS, type Lang, t } from '@/lib/i18n';
import { langBase } from '@/lib/base';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import type { ArticleMeta, LayerMeta } from '../../lib/content';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const CONTENT_ROOT = path.resolve(import.meta.dirname, '../../../content');

interface ChangeEntry {
  date: string;
  law: string;
  article: number;
  suffix: string;
  layer: string;
  version: number;
  slug: string;
}

const changes: ChangeEntry[] = [];

let lawDirs: string[] = [];
try {
  lawDirs = fs.readdirSync(CONTENT_ROOT, { withFileTypes: true })
    .filter((e) => e.isDirectory())
    .map((e) => e.name);
} catch {
  lawDirs = [];
}

for (const lawDir of lawDirs) {
  const lawPath = path.join(CONTENT_ROOT, lawDir);
  const artDirs = fs.readdirSync(lawPath, { withFileTypes: true })
    .filter((e) => e.isDirectory() && e.name.startsWith('art-'));

  for (const artDir of artDirs) {
    const metaPath = path.join(lawPath, artDir.name, 'meta.yaml');
    try {
      const raw = fs.readFileSync(metaPath, 'utf-8');
      const meta = yaml.load(raw) as ArticleMeta;
      if (!meta.layers) continue;

      const match = artDir.name.match(/^art-(\d+)([a-z]*)$/);
      if (!match) continue;
      const num = parseInt(match[1], 10);
      const suffix = match[2] || '';
      const slug = `art-${num}${suffix}`;

      for (const [layerName, layerMeta] of Object.entries(meta.layers)) {
        const lm = layerMeta as LayerMeta;
        if (lm.last_generated) {
          changes.push({
            date: lm.last_generated,
            law: meta.law,
            article: meta.article,
            suffix: meta.article_suffix || '',
            layer: layerName,
            version: lm.version || 1,
            slug,
          });
        }
      }
    } catch {
      // Skip articles with invalid meta
    }
  }
}

changes.sort((a, b) => b.date.localeCompare(a.date));

const byDate = new Map<string, ChangeEntry[]>();
for (const change of changes) {
  if (!byDate.has(change.date)) byDate.set(change.date, []);
  byDate.get(change.date)!.push(change);
}

const dates = Array.from(byDate.keys()).sort().reverse();

const layerLabels: Record<string, Record<Lang, string>> = {
  summary: { de: 'Übersicht', fr: 'Aperçu', it: 'Panoramica', en: 'Overview' },
  doctrine: { de: 'Doktrin', fr: 'Doctrine', it: 'Dottrina', en: 'Doctrine' },
  caselaw: { de: 'Rechtsprechung', fr: 'Jurisprudence', it: 'Giurisprudenza', en: 'Case Law' },
};
---

<Base title={t('changelog.title', lang)} lang={lang} pagePath="/changelog" description="Tägliches Änderungsprotokoll der Kommentare.">
  <Breadcrumb lang={lang} items={[{ label: t('changelog.title', lang) }]} />

  <article class="changelog-page content-column">
    <header class="changelog-header">
      <h1>{t('changelog.title', lang)}</h1>
    </header>

    {dates.length === 0 ? (
      <div class="changelog-empty">
        <p class="text-muted">{t('changelog.empty', lang)}</p>
      </div>
    ) : (
      dates.map((date) => {
        const entries = byDate.get(date)!;
        return (
          <section class="changelog-day">
            <h2 class="changelog-date font-mono">{date}</h2>
            <ul class="changelog-entries">
              {entries.map((entry) => (
                <li>
                  <a href={`${langBase(lang)}/${entry.law.toLowerCase()}/${entry.slug}?layer=${entry.layer}`}>
                    <span class="change-law">{entry.law}</span>
                    <span class="change-article">
                      Art.&nbsp;{entry.article}{entry.suffix}
                    </span>
                    <span class="change-layer text-sm text-muted">
                      {layerLabels[entry.layer]?.[lang] || entry.layer}
                    </span>
                    <span class="change-version text-xs font-mono text-muted">
                      v{entry.version}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })
    )}
  </article>
</Base>

<style>
  .changelog-header {
    margin-bottom: var(--space-5);
  }

  .changelog-header h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .changelog-header p {
    margin-top: var(--space-2);
  }

  .changelog-empty {
    padding: var(--space-6) var(--space-4);
    text-align: center;
    border: 1px solid var(--color-border);
  }

  .changelog-day {
    margin-top: var(--space-4);
  }

  .changelog-date {
    font-size: var(--text-md);
    color: var(--color-text);
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
  }

  .changelog-entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .changelog-entries li {
    margin: 0;
  }

  .changelog-entries a {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 8px var(--space-1);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition-fast);
    font-size: var(--text-sm);
  }

  .changelog-entries a:hover {
    background: var(--color-rule-light);
  }

  .change-law {
    font-weight: 600;
    min-width: 50px;
    color: var(--color-text);
    font-size: var(--text-xs);
    text-transform: uppercase;
  }

  .change-article {
    min-width: 80px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .change-layer {
    flex: 1;
  }
</style>
