---
// site/src/pages/about.astro
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import fs from 'node:fs';
import path from 'node:path';

// Read guidelines/global.md for the methodology section
const guidelinesPath = path.resolve(import.meta.dirname, '../../../guidelines/global.md');
let guidelinesContent = '';
try {
  guidelinesContent = fs.readFileSync(guidelinesPath, 'utf-8');
} catch {
  guidelinesContent = '';
}

// Extract the Leitbild section
const leitbildMatch = guidelinesContent.match(/## Leitbild\n\n([\s\S]*?)(?=\n---)/);
const leitbild = leitbildMatch ? leitbildMatch[1].trim() : '';
---

<Base title="About" description="Mission, Methodik und Richtlinien von Open Legal Commentary.">
  <Breadcrumb items={[{ label: 'About' }]} />

  <article class="about-page content-column">
    <h1>About Open Legal Commentary</h1>

    <section class="about-section">
      <h2>Mission</h2>
      <p>
        openlegalcommentary.ch macht das Schweizer Bundesrecht fuer alle zugaenglich.
        Jeder Kommentarartikel ist auf drei Ebenen lesbar: als knapper Ueberblick,
        als wissenschaftlich fundierte Doktrin und als vollstaendige Rechtsprechungsuebersicht.
      </p>
      {leitbild && <p>{leitbild}</p>}
    </section>

    <section class="about-section">
      <h2>Methodik</h2>
      <p>
        Die Kommentare werden mittels KI generiert und folgen strengen Redaktionsrichtlinien.
        Jede Rechtsaussage ist auf eine Primaerquelle zurueckfuehrbar. Doktrinaere Positionen
        werden praezise zugeschrieben. Mindermeinungen werden fair und vollstaendig dargestellt.
      </p>

      <h3>Drei Ebenen</h3>
      <dl class="method-list">
        <dt>Ebene 1 — Uebersicht (Summary)</dt>
        <dd>Verstaendliche Zusammenfassung auf B1-Sprachniveau (150-300 Woerter). Was regelt die Norm? Wer ist betroffen? Was sind die Rechtsfolgen?</dd>

        <dt>Ebene 2 — Doktrin</dt>
        <dd>Wissenschaftliche Analyse mit Randziffern (N. 1, N. 2, ...). Entstehungsgeschichte, systematische Einordnung, Tatbestandsmerkmale, Rechtsfolgen, Streitstaende.</dd>

        <dt>Ebene 3 — Rechtsprechung</dt>
        <dd>Vollstaendige BGE-Uebersicht, thematisch gruppiert. Pro Entscheid: BGE-Referenz, Leitsatz, Relevanz, Blockzitat der entscheidenden Passage.</dd>
      </dl>
    </section>

    <section class="about-section">
      <h2>Abgedeckte Gesetze</h2>
      <ul>
        <li><strong>BV</strong> — Bundesverfassung (SR 101)</li>
        <li><strong>ZGB</strong> — Zivilgesetzbuch (SR 210)</li>
        <li><strong>OR</strong> — Obligationenrecht (SR 220)</li>
        <li><strong>ZPO</strong> — Zivilprozessordnung (SR 272)</li>
        <li><strong>StGB</strong> — Strafgesetzbuch (SR 311.0)</li>
        <li><strong>StPO</strong> — Strafprozessordnung (SR 312.0)</li>
        <li><strong>SchKG</strong> — SchKG (SR 281.1)</li>
        <li><strong>VwVG</strong> — VwVG (SR 172.021)</li>
      </ul>
    </section>

    <section class="about-section">
      <h2>Zitierformat</h2>
      <p>Verbindliche Zitierformate:</p>
      <ul class="citation-examples font-mono text-sm">
        <li><strong>BGE:</strong> BGE 130 III 182 E. 5.5.1</li>
        <li><strong>BGer:</strong> Urteil 4A_123/2024 vom 15.3.2024 E. 3.2</li>
        <li><strong>Literatur:</strong> Gauch/Schluep/Schmid, OR AT, 11. Aufl. 2020, N 2850</li>
        <li><strong>Botschaft:</strong> BBl 2001 4202</li>
      </ul>
    </section>

    <section class="about-section">
      <h2>Lizenz</h2>
      <p>
        Inhalte stehen unter <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">CC BY-SA 4.0</a>.
        Code steht unter der <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT-Lizenz</a>.
      </p>
    </section>

    <section class="about-section">
      <h2>Kontakt</h2>
      <p>
        Projekt auf <a href="https://github.com/openlegalcommentary" target="_blank" rel="noopener">GitHub</a>.
        Powered by <a href="https://opencaselaw.ch" target="_blank" rel="noopener">opencaselaw.ch</a>.
      </p>
    </section>
  </article>
</Base>

<style>
  .about-section {
    margin-bottom: var(--space-4);
  }

  .about-section h2 {
    margin-top: var(--space-4);
  }

  .method-list {
    margin: var(--space-2) 0;
  }

  .method-list dt {
    font-family: var(--font-heading);
    font-weight: 600;
    margin-top: var(--space-2);
  }

  .method-list dd {
    margin-left: var(--space-2);
    color: var(--color-text-secondary);
  }

  .citation-examples {
    list-style: none;
    padding: var(--space-2);
    background: var(--color-code-bg);
    border-radius: 6px;
  }

  .citation-examples li {
    margin-bottom: var(--space-1);
  }
</style>
