---
// site/src/pages/[law]/index.astro
import { BASE, HOME } from '@/lib/base';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SearchBar from '../../components/SearchBar.astro';
import { LAWS, getLawByAbbr } from '../../lib/laws';
import { listArticles, getLawStats } from '../../lib/content';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  return LAWS.map((law) => ({
    params: { law: law.abbr.toLowerCase() },
  }));
}

const { law: lawParam } = Astro.params;
const lawInfo = getLawByAbbr(lawParam!);

if (!lawInfo) {
  return Astro.redirect(HOME);
}

const articles = listArticles(lawInfo.abbr);
const stats = getLawStats(lawInfo.abbr);

// Load structural data (Titel/Kapitel/Abschnitt) if available
interface StructureEntry {
  type: 'titel' | 'kapitel' | 'abschnitt';
  label: string;
  name: string;
  from?: number;
  to?: number;
}

let structure: StructureEntry[] = [];
try {
  const structPath = path.resolve('..', 'scripts', 'law_structures.json');
  const structData = JSON.parse(fs.readFileSync(structPath, 'utf-8'));
  structure = structData[lawInfo.abbr] || [];
} catch {
  // No structure data available — show flat list
}

// Build a map: article number → structural headings that appear before it
const headingsBefore = new Map<number, StructureEntry[]>();

if (structure.length > 0) {
  // Entries without 'from' are pure headings (e.g. "2. Titel" without articles)
  // Entries with 'from' mark where articles begin under that heading
  for (const entry of structure) {
    if (entry.from != null) {
      if (!headingsBefore.has(entry.from)) {
        headingsBefore.set(entry.from, []);
      }
      headingsBefore.get(entry.from)!.push(entry);
    }
  }

  // Pure headings (no from/to) should appear before the next entry that has a 'from'
  for (let i = 0; i < structure.length; i++) {
    const entry = structure[i];
    if (entry.from == null) {
      // Find the next entry with a 'from'
      for (let j = i + 1; j < structure.length; j++) {
        if (structure[j].from != null) {
          const key = structure[j].from!;
          if (!headingsBefore.has(key)) {
            headingsBefore.set(key, []);
          }
          // Insert before existing entries at this position
          headingsBefore.get(key)!.unshift(entry);
          break;
        }
      }
    }
  }
}

// Also handle Gemeinden article (Art. 50) which falls between sections
// by checking for gaps in the structure
---

<Base title={`${lawInfo.abbr} — ${lawInfo.name}`} description={lawInfo.fullTitle}>
  <Breadcrumb items={[{ label: lawInfo.abbr }]} />

  <header class="law-header">
    <div class="law-header-top">
      <h1>{lawInfo.abbr}</h1>
      <span class="law-sr font-mono text-muted">SR {lawInfo.sr}</span>
    </div>
    <p class="law-full-title text-secondary">{lawInfo.fullTitle}</p>
    <div class="law-meta text-sm text-muted font-heading">
      <span>{stats.totalArticles} Artikel</span>
      {stats.withContent > 0 && (
        <>
          <span>&middot;</span>
          <span>{stats.withContent} kommentiert</span>
        </>
      )}
    </div>
    <div class="law-progress">
      <div class="progress-bar">
        <div class="progress-fill" style={`width: ${Math.max(stats.withContent / stats.totalArticles * 100, stats.withContent > 0 ? 1 : 0)}%`}></div>
      </div>
      <span class="progress-label text-xs text-muted font-mono">
        {Math.round(stats.withContent / stats.totalArticles * 100)}%
      </span>
    </div>
  </header>

  <div class="law-search">
    <SearchBar placeholder={`In ${lawInfo.abbr} suchen — z.B. "Haftung" oder "Art. 41"`} />
  </div>

  <section class="toc">
    <h2>Inhaltsverzeichnis</h2>

    <ul class="toc-list">
      {articles.map((art) => {
        const suffix = art.meta.article_suffix || '';
        const displayNum = `${art.meta.article}${suffix}`;
        const hasContent = Object.keys(art.meta.layers).length > 0;
        const artNum = art.meta.article;

        // Check if there are structural headings before this article
        const headings = headingsBefore.get(artNum) || [];

        return (
          <>
            {headings.map((h) => {
              const cls = `toc-heading toc-heading-${h.type}`;
              return (
                <li class={cls}>
                  <span class="toc-heading-label">{h.label}</span>
                  <span class="toc-heading-name">{h.name}</span>
                </li>
              );
            })}
            <li class:list={['toc-item', { 'has-content': hasContent }]}>
              <a href={`${BASE}/${lawParam}/${art.slug}`}>
                <span class="toc-num font-mono">Art.&nbsp;{displayNum}</span>
                <span class="toc-title">{art.meta.title}</span>
                {hasContent && <span class="toc-badge" title="Kommentiert">●</span>}
              </a>
            </li>
          </>
        );
      })}
    </ul>
  </section>
</Base>

<style>
  .law-header {
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-light);
  }

  .law-header-top {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .law-header h1 {
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }

  .law-full-title {
    font-size: var(--text-md);
    margin-bottom: var(--space-1);
  }

  .law-meta {
    display: flex;
    gap: var(--space-1);
  }

  .law-progress {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-2);
  }

  .progress-bar {
    flex: 1;
    max-width: 200px;
    height: 4px;
    background: var(--color-bg-alt);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 2px;
    transition: width 0.6s var(--ease-out);
  }

  .law-search {
    margin-bottom: var(--space-4);
  }

  .toc h2 {
    margin-bottom: var(--space-3);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Structural headings */
  .toc-heading {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .toc-heading-titel {
    margin-top: var(--space-4);
    padding: var(--space-2) 0;
    border-bottom: 2px solid var(--color-accent);
  }

  .toc-heading-titel .toc-heading-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-weight: 600;
    display: block;
    margin-bottom: 2px;
  }

  .toc-heading-titel .toc-heading-name {
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--color-text);
  }

  .toc-heading-kapitel {
    margin-top: var(--space-3);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .toc-heading-kapitel .toc-heading-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-weight: 500;
    margin-right: var(--space-1);
  }

  .toc-heading-kapitel .toc-heading-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  .toc-heading-abschnitt {
    margin-top: var(--space-2);
    padding: 4px 0 4px var(--space-2);
  }

  .toc-heading-abschnitt .toc-heading-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-right: 4px;
  }

  .toc-heading-abschnitt .toc-heading-name {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Article items — single column */
  .toc-item a {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: 6px var(--space-1);
    text-decoration: none;
    color: var(--color-text);
    border-radius: 4px;
    transition: background var(--transition-fast);
    font-size: var(--text-sm);
  }

  .toc-item a:hover {
    background: var(--color-bg-alt);
  }

  .toc-num {
    color: var(--color-text-muted);
    min-width: 80px;
    font-size: var(--text-xs);
    flex-shrink: 0;
  }

  .toc-title {
    flex: 1;
  }

  .toc-badge {
    color: var(--color-accent);
    font-size: 8px;
    flex-shrink: 0;
  }

  /* First titel shouldn't have top margin */
  .toc-list > .toc-heading-titel:first-child {
    margin-top: 0;
  }
</style>
