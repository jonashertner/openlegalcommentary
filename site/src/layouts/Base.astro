---
// site/src/layouts/Base.astro
import { ViewTransitions } from 'astro:transitions';
import { type Lang, LANGS, t } from '@/lib/i18n';
import { BASE, langBase } from '@/lib/base';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  lang?: Lang;
  pagePath?: string;
}

const {
  title,
  lang = 'de',
  pagePath = '/',
  description = t('meta.description', lang),
  currentPath = Astro.url.pathname,
} = Astro.props;

const siteSubtitle: Record<Lang, string> = {
  de: 'Schweizer Bundesrecht',
  fr: 'Droit fédéral suisse',
  it: 'Diritto federale svizzero',
  en: 'Swiss Federal Law',
};
const fullTitle = title === 'Home'
  ? `Open Legal Commentary — ${siteSubtitle[lang]}`
  : `${title} — Open Legal Commentary`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="current-lang" content={lang} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="canonical" href={`${(Astro.site?.toString() || '').replace(/\/$/, '')}${langBase('de')}${pagePath}`} />
    {LANGS.map((l) => (
      <link rel="alternate" hreflang={l} href={`${(Astro.site?.toString() || '').replace(/\/$/, '')}${langBase(l)}${pagePath}`} />
    ))}
    <link rel="alternate" type="application/rss+xml" title="Open Legal Commentary" href="/feed.xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Open Legal Commentary" />
    <meta property="og:url" content={`${(Astro.site?.toString() || '').replace(/\/$/, '')}${langBase(lang)}${pagePath}`} />
    <meta property="og:locale" content={lang === 'de' ? 'de_CH' : lang === 'fr' ? 'fr_CH' : lang === 'it' ? 'it_CH' : 'en'} />
    <meta property="og:image" content={`${(Astro.site?.toString() || '').replace(/\/$/, '')}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${(Astro.site?.toString() || '').replace(/\/$/, '')}/og-image.png`} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="base-url" content={BASE} />
    <ViewTransitions />
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        if (saved) {
          document.documentElement.setAttribute('data-theme', saved);
        }
        // Restore theme after View Transitions DOM swap
        document.addEventListener('astro:after-swap', function() {
          const t = localStorage.getItem('theme');
          if (t) document.documentElement.setAttribute('data-theme', t);
        });
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div data-pagefind-ignore>
      <Header currentPath={currentPath} lang={lang} pagePath={pagePath} />
    </div>
    <main id="main-content">
      <div class="page-wrapper">
        <slot />
      </div>
    </main>
    <div data-pagefind-ignore>
      <Footer lang={lang} />
    </div>
  </body>
</html>
